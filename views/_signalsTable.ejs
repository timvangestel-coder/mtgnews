<table class="w-full text-left">
  <thead>
    <tr class="border-b text-sm text-gray-500">
      <th class="py-2 px-3">Published</th>
      <th class="py-2 px-3">Time</th>
      <th class="py-2 px-3">Title</th>
      <th class="py-2 px-3">Q&A</th>
      <th class="py-2 px-3">Sentiment</th>
    </tr>
  </thead>
  <tbody>
    <% if (!signals || signals.length === 0) { %>
      <tr><td colspan="5" class="py-4 px-3 text-gray-500">No signals found.</td></tr>
    <% } %>
    <% (signals || []).forEach(signal => { %>
      <%
        const date = signal.published_at ? new Date(signal.published_at) : new Date();
        const dateStr = date.toLocaleDateString();
        const timeStr = date.toLocaleTimeString();
        const isIrrelevant = signal.processing_state === 'irrelevant';
        const title = isIrrelevant ? '[Irrelevant]' : (signal.generated_title || signal.title || '');
        const sentiment = signal.overall_sentiment || 3;
        const colors = ['', 'bg-red-600', 'bg-orange-500', 'bg-yellow-500', 'bg-lime-500', 'bg-green-600'];
        // Issue #116: Q&A ratio - "X/Y" or "—" when no questions
        const qaRatio = signal.qaTotal != null ? signal.qaAnswered + '/' + signal.qaTotal : '\u2014';
        // New indicator: show if created_at is within the last 24 hours
        const isNew = (Date.now() - signal.created_at) < 86400 * 1000;
      %>
      <tr class="border-b hover:bg-gray-50 cursor-pointer <%= isIrrelevant ? 'opacity-50' : '' %>" onclick="location.href='/signals/<%= signal.video_id %>'">
        <td class="py-2 px-3 text-sm"><%= dateStr %></td>
        <td class="py-2 px-3 text-sm"><%= timeStr %></td>
        <td class="py-2 px-3 text-sm">
          <%= title %>
          <% if (isNew) { %><span style="color: #eab308; margin-left: 6px;">NEW</span><% } %>
        </td>
        <td class="py-2 px-3 text-sm text-gray-500"><%= qaRatio %></td>
        <td class="py-2 px-3">
          <span class="<%= colors[sentiment] || 'bg-gray-400' %> text-white rounded-full px-2 py-0.5 text-xs">
            <%= sentiment %>
          </span>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<!-- Signal count for chat panel scope badge updates -->
<span data-signal-count style="display:none" aria-hidden="true"><%= total %></span>

<!-- Pagination -->
<div class="flex justify-between items-center mt-4">
  <span class="text-sm text-gray-500">
    Showing <%= signals.length %> of <%= total %> signals
  </span>
  <div class="flex gap-2">
    <% if (page > 1) { %>
      <%
        const prevParams = new URLSearchParams();
        if (topicKey) prevParams.set('topicKey', topicKey);
        if (channelId) prevParams.set('channelId', channelId);
        if (showIrrelevant) prevParams.set('showIrrelevant', 'true');
        if (dateFilter) prevParams.set('dateFilter', dateFilter);
        prevParams.set('page', String(page - 1));
        prevParams.set('htmx', 'true');
      %>
      <button hx-get="/signals?<%= prevParams.toString() %>"
              hx-target="#signals-table"
              class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">
        Previous
      </button>
    <% } %>
    <% if (page < totalPages) { %>
      <%
        const nextParams = new URLSearchParams();
        if (topicKey) nextParams.set('topicKey', topicKey);
        if (channelId) nextParams.set('channelId', channelId);
        if (showIrrelevant) nextParams.set('showIrrelevant', 'true');
        if (dateFilter) nextParams.set('dateFilter', dateFilter);
        nextParams.set('page', String(page + 1));
        nextParams.set('htmx', 'true');
      %>
      <button hx-get="/signals?<%= nextParams.toString() %>"
              hx-target="#signals-table"
              class="px-3 py-1 bg-gray-200 rounded text-sm hover:bg-gray-300">
        Next
      </button>
    <% } %>
  </div>
</div>