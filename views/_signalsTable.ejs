<div x-data="UiState.signalListView()" class="space-y-2">
  <% if (!signals || signals.length === 0) { %>
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-surface-200 dark:border-muted-700 p-4 text-center text-sm leading-relaxed text-muted-500 dark:text-muted-400">
      No signals found.
    </div>
  <% } %>
  <% (signals || []).forEach(signal => { %>
     <%
       const date = signal.published_at ? new Date(signal.published_at) : new Date();
       const dateStr = date.toLocaleDateString();
       const timeStr = date.toLocaleTimeString();
       const isIrrelevant = signal.processing_state === 'irrelevant';
       const title = signal.generated_title || signal.title || '';
       const sentiment = signal.overall_sentiment || 3;
        // Sentiment colour tokens: 1=red, 2=orange, 3=yellow/amber, 4=lime, 5=green
        const sentimentBg = ['bg-danger-500', 'bg-orange-500', 'bg-warning-500', 'bg-lime-500', 'bg-success-600'];
        const sentimentBgLight = ['bg-danger-100 dark:bg-danger-900', 'bg-orange-100 dark:bg-orange-900', 'bg-warning-100 dark:bg-warning-900', 'bg-lime-100 dark:bg-lime-900', 'bg-success-100 dark:bg-success-900'];
        const sentimentText = ['text-danger-700 dark:text-danger-300', 'text-orange-700 dark:text-orange-300', 'text-warning-700 dark:text-warning-300', 'text-lime-700 dark:text-lime-300', 'text-success-700 dark:text-success-300'];
        // Clamp sentiment to 1-5 range and convert to 0-based index
        const sIdx = Math.max(0, Math.min(sentiment - 1, 4));
       // Issue #116: Q&A ratio
       const qaRatio = signal.qaTotal != null ? signal.qaAnswered + '/' + signal.qaTotal : '\u2014';
       // New indicator: within last 24 hours
       const isNew = (Date.now() - signal.created_at) < 86400 * 1000;
       // Issue #183: reviewed indicator
       const isReviewed = signal.reviewed;
       // Resolve channel display name from channelsMap (passed by router)
       const channelId = signal.channel_id || '';
       const channelName = (channelsMap && channelsMap[channelId]) || channelId || '?';
       const channelInitial = String(channelName).charAt(0).toUpperCase();
     %>
    <div
      class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-3 cursor-pointer hover:shadow-card-md transition-shadow duration-default <%= isIrrelevant ? 'opacity-50' : '' %>"
      onclick="location.href='/signals/<%= signal.video_id %>'">

      <!-- Card row: avatar + content + sentiment -->
      <div class="flex items-start gap-3">

        <!-- Channel avatar -->
        <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-100 dark:bg-brand-900 text-brand-600 dark:text-brand-300 flex items-center justify-center font-semibold text-sm">
          <%= channelInitial %>
        </div>

         <!-- Title + metadata -->
         <div class="flex-1 min-w-0">
           <!-- Title row -->
           <div class="flex items-center gap-2 flex-wrap">
             <span class="text-sm font-medium text-muted-800 dark:text-muted-200 truncate"><%= title %></span>
             <% if (isNew) { %>
               <span class="inline-flex items-center rounded-full bg-warning-100 dark:bg-warning-900 px-2 py-0.5 text-xs font-medium text-warning-600 dark:text-warning-300">NEW</span>
             <% } %>
             <% if (isReviewed) { %>
               <span class="inline-flex items-center rounded-full bg-brand-100 dark:bg-brand-900 px-2 py-0.5 text-xs font-semibold text-brand-600 dark:text-brand-300">REVIEWED</span>
             <% } %>
           </div>

            <!-- Metadata row — structured with styled chips -->
           <div class="text-xs mt-1 flex items-center gap-2 flex-wrap">
             <span class="inline-flex items-center gap-1 text-muted-500 dark:text-muted-400">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
               </svg>
               <%= dateStr %>
             </span>
             <span class="inline-flex items-center gap-1 text-muted-500 dark:text-muted-400">
               <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                 <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
               </svg>
               <%= timeStr %>
             </span>
             <span class="inline-flex items-center rounded-md bg-slate-100 dark:bg-slate-700 px-1.5 py-0.5 text-muted-600 dark:text-muted-300 font-medium">
               <%= channelName %>
            </span>
             <% if (signal.qaTotal != null) { %>
               <span class="inline-flex items-center rounded-md bg-brand-50 dark:bg-brand-900 px-1.5 py-0.5 text-brand-600 dark:text-brand-300 font-medium">
                 Q&A <%= qaRatio %>
               </span>
             <% } else { %>
               <span class="text-muted-400 dark:text-muted-500">Q&A —</span>
             <% } %>
           </div>
         </div>

         <!-- Sentiment circular badge -->
         <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold <%= sentimentBgLight[sIdx] || 'bg-muted-100 dark:bg-muted-800' %> <%= sentimentText[sIdx] || 'text-muted-600 dark:text-muted-300' %>">
           <%= sentiment %>
         </div>

      </div>
    </div>
  <% }) %>
</div>

<!-- Signal count for chat panel scope badge updates -->
<span data-signal-count class="hidden" aria-hidden="true"><%= total %></span>

<!-- Pagination — Body level with vertical rhythm -->
<div class="flex justify-between items-center mt-4 pt-4 border-t border-surface-200 dark:border-muted-700">
  <span class="text-sm leading-relaxed text-muted-500 dark:text-muted-400">
    Showing <%= signals.length %> of <%= total %> signals
  </span>
  <div class="flex gap-2">
    <% if (page > 1) { %>
      <%
        const prevParams = new URLSearchParams();
        if (topicKey) prevParams.set('topicKey', topicKey);
        if (channelId) prevParams.set('channelId', channelId);
        if (showIrrelevant) prevParams.set('showIrrelevant', 'true');
        if (showUnreviewed !== true) prevParams.set('showUnreviewed', 'false');
        if (dateFilter) prevParams.set('dateFilter', dateFilter);
        prevParams.set('page', String(page - 1));
        prevParams.set('htmx', 'true');
      %>
      <button hx-get="/signals?<%= prevParams.toString() %>"
              hx-target="#signals-table"
              class="px-3 py-1 bg-surface-200 dark:bg-slate-700 rounded text-sm hover:bg-surface-300 dark:hover:bg-slate-600 text-muted-700 dark:text-muted-200 transition">
        Previous
      </button>
    <% } %>
    <% if (page < totalPages) { %>
      <%
        const nextParams = new URLSearchParams();
        if (topicKey) nextParams.set('topicKey', topicKey);
        if (channelId) nextParams.set('channelId', channelId);
        if (showIrrelevant) nextParams.set('showIrrelevant', 'true');
        if (showUnreviewed !== true) nextParams.set('showUnreviewed', 'false');
        if (dateFilter) nextParams.set('dateFilter', dateFilter);
        nextParams.set('page', String(page + 1));
        nextParams.set('htmx', 'true');
      %>
      <button hx-get="/signals?<%= nextParams.toString() %>"
              hx-target="#signals-table"
              class="px-3 py-1 bg-surface-200 dark:bg-slate-700 rounded text-sm hover:bg-surface-300 dark:hover:bg-slate-600 text-muted-700 dark:text-muted-200 transition">
        Next
      </button>
    <% } %>
  </div>
</div>