<!-- Topics Tab — 4-column table with Add/Edit modal -->
<div x-data="UiState.topicModal()">

  <!-- Header + Add Topic button -->
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-xl font-semibold tracking-heading text-muted-900 dark:text-muted-100">Topics</h3>
    <button type="button"
      @click="openAdd()"
      class="px-3 py-1.5 bg-success-600 text-white rounded-card hover:bg-success-700 text-sm font-medium focus:outline-none focus-visible:ring-2 focus-visible:ring-success-500">
      + Add Topic
    </button>
  </div>

  <!-- Topics Table -->
  <div>
    <% if (topics && topics.length > 0) { %>
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-surface-200 dark:border-muted-700">
            <th class="py-2 px-3 font-medium text-muted-700 dark:text-muted-300">Key</th>
            <th class="py-2 px-3 font-medium text-muted-700 dark:text-muted-300">Short Name</th>
            <th class="py-2 px-3 font-medium text-muted-700 dark:text-muted-300">Channels</th>
            <th class="py-2 px-3 font-medium text-muted-700 dark:text-muted-300">Actions</th>
          </tr>
        </thead>
        <tbody x-data="UiState.topicActions()">
          <% topics.forEach(function(topic) { %>
            <%- include('_topicRow', { topic }) %>
          <% }); %>
        </tbody>
      </table>
    <% } else { %>
      <p class="text-sm leading-relaxed text-muted-500 dark:text-muted-400">No topics yet. Add one with the button above.</p>
    <% } %>
  </div>

  <!-- Add/Edit Topic Modal -->
  <div x-show="open" x-cloak
    class="fixed inset-0 z-50 flex items-center justify-center p-4"
    @keydown.escape.window="close()"
    role="dialog" aria-modal="true" :aria-labelledby="mode === 'add' ? 'modal-title-add' : 'modal-title-edit'">

    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/50 dark:bg-black/70" @click="close()"></div>

    <!-- Modal panel -->
    <div class="relative z-10 w-full max-w-2xl bg-white dark:bg-muted-900 rounded-card shadow-xl border border-surface-200 dark:border-muted-700 flex flex-col max-h-[90vh]"
      x-trap.inert.noscroll="open"
      @keydown.escape.stop="close()">

      <!-- Modal header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-surface-200 dark:border-muted-700">
        <h4 class="text-lg font-semibold text-muted-900 dark:text-muted-100"
            :id="mode === 'add' ? 'modal-title-add' : 'modal-title-edit'"
            x-text="mode === 'add' ? 'Add Topic' : ('Edit: ' + topic.short_name)"></h4>
        <button type="button" @click="close()"
          class="text-muted-400 hover:text-muted-600 dark:hover:text-muted-200 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded"
          aria-label="Close modal">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
        </button>
      </div>

      <!-- Modal body -->
      <div class="overflow-y-auto px-6 py-4 flex-1">
        <form
          :id="mode === 'add' ? 'topic-add-form' : 'topic-edit-form'"
          :hx-post="mode === 'add' ? '/admin/topics' : null"
          :hx-patch="mode === 'edit' ? '/admin/topics/' + topic.id : null"
          hx-swap="none"
          @htmx:after-request="if ($event.detail.successful) { close(); document.body.dispatchEvent(new CustomEvent('refreshTopics')); }"
          class="flex flex-col gap-4"
          x-ref="modalForm">

          <!-- Key -->
          <div>
            <label class="block text-sm font-medium text-muted-700 dark:text-muted-300 mb-1" for="modal-topic-key">Key</label>
            <input id="modal-topic-key" type="text" name="key" :value="topic.key || ''" placeholder="slug-key"
              class="w-full px-3 py-2 border border-surface-200 dark:border-muted-600 rounded-input bg-white dark:bg-muted-800 text-muted-800 dark:text-muted-100 font-mono focus:outline-none focus:ring-2 focus:ring-brand-500"
              :readonly="mode === 'edit'"
              required />
          </div>

          <!-- Short Name -->
          <div>
            <label class="block text-sm font-medium text-muted-700 dark:text-muted-300 mb-1" for="modal-topic-short-name">Short Name</label>
            <input id="modal-topic-short-name" type="text" name="short_name" :value="topic.short_name || ''" placeholder="Display Name"
              class="w-full px-3 py-2 border border-surface-200 dark:border-muted-600 rounded-input bg-white dark:bg-muted-800 text-muted-800 dark:text-muted-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
              required />
          </div>

          <!-- Filter Text -->
          <div>
            <label class="block text-sm font-medium text-muted-700 dark:text-muted-300 mb-1" for="modal-topic-filter">Filter Text</label>
            <textarea id="modal-topic-filter" name="filter_text" rows="3"
              :value="topic.filter_text || ''"
              class="w-full px-3 py-2 border border-surface-200 dark:border-muted-600 rounded-input text-sm bg-white dark:bg-muted-800 text-muted-800 dark:text-muted-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
              x-text="topic.filter_text || ''"></textarea>
          </div>

          <!-- Summary Prompt -->
          <div>
            <label class="block text-sm font-medium text-muted-700 dark:text-muted-300 mb-1" for="modal-topic-summary-prompt">Summary Prompt</label>
            <textarea id="modal-topic-summary-prompt" name="summary_prompt" rows="4"
              placeholder="(using default)"
              class="w-full px-3 py-2 border border-surface-200 dark:border-muted-600 rounded-input text-sm bg-white dark:bg-muted-800 text-muted-800 dark:text-muted-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
              x-text="topic.summary_prompt || ''"></textarea>
          </div>

          <!-- Multi-Signal Summary Prompt -->
          <div>
            <label class="block text-sm font-medium text-muted-700 dark:text-muted-300 mb-1" for="modal-topic-multi-signal-prompt">Multi-Signal Summary Prompt</label>
            <textarea id="modal-topic-multi-signal-prompt" name="multi_signal_summary_prompt" rows="4"
              placeholder="(using default)"
              class="w-full px-3 py-2 border border-surface-200 dark:border-muted-600 rounded-input text-sm bg-white dark:bg-muted-800 text-muted-800 dark:text-muted-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
              x-text="topic.multi_signal_summary_prompt || ''"></textarea>
          </div>

        </form>
      </div>

      <!-- Modal footer -->
      <div class="flex gap-2 justify-end px-6 py-4 border-t border-surface-200 dark:border-muted-700">
        <button type="button" @click="close()"
          class="px-4 py-2 bg-surface-100 dark:bg-muted-700 text-muted-700 dark:text-muted-200 rounded-card hover:bg-surface-200 dark:hover:bg-muted-600 text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
          Cancel
        </button>
        <button type="submit" :form="mode === 'add' ? 'topic-add-form' : 'topic-edit-form'"
          class="px-4 py-2 bg-success-600 text-white rounded-card hover:bg-success-700 text-sm font-medium transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-success-500">
          Save
        </button>
      </div>
    </div>
  </div>

</div>