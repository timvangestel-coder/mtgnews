<!-- LLM Settings -->
<div class="mb-8">
  <h3 class="text-xl font-semibold tracking-heading mb-4 text-muted-900 dark:text-muted-100">LLM Settings</h3>

  <!-- Global Default Summary Prompt -->
  <div class="mb-6">
    <h4 class="text-lg font-medium tracking-heading mb-2 text-muted-800 dark:text-muted-200">Global Default Summary Prompt</h4>
    <p class="text-sm leading-relaxed text-muted-500 dark:text-muted-400 mb-2">
      Sets the default prompt template for all topics that do not have a custom prompt configured.
      <% if (defaultPrompt === null || defaultPrompt === undefined) { %>
        <span class="text-muted-400 dark:text-muted-500">Currently using compiled default (no DB override set).</span>
      <% } else { %>
        <span class="text-success-600 dark:text-success-400">Custom global prompt is active.</span>
      <% } %>
    </p>
    <form hx-post="/admin/settings/default-prompt" hx-swap="none" class="flex flex-col gap-2 max-w-3xl">
      <textarea name="prompt" rows="8"
          class="px-3 py-2 border border-surface-200 dark:border-muted-600 rounded-input text-sm font-mono bg-white dark:bg-muted-800 text-muted-800 dark:text-muted-100 focus:outline-none focus:ring-2 focus:ring-brand-500"
          placeholder="Leave empty to use compiled default template"><%= defaultPrompt || '' %></textarea>
      <div class="flex gap-2 items-center">
        <button type="submit" class="px-4 py-2 bg-success-600 text-white rounded-card hover:bg-success-700 text-sm font-medium">Save</button>
        <span class="text-xs text-muted-400 dark:text-muted-500">Setting empty clears the override and falls back to compiled default.</span>
      </div>
    </form>
  </div>
</div>

<!-- Danger Zone -->
<div class="border-t border-surface-200 dark:border-muted-700 pt-6">
  <h3 class="text-xl font-semibold tracking-heading mb-1 text-warning-700 dark:text-warning-400">Danger Zone</h3>
  <p class="text-sm leading-relaxed text-muted-500 dark:text-muted-400 mb-5">
    Rows marked as deleted (<code class="text-xs font-mono bg-surface-100 dark:bg-muted-700 px-1 rounded">deleted_at</code> set).
    Use <strong>Undo All</strong> to restore them, or <strong>Purge All</strong> to permanently remove them.
  </p>

  <!-- Summary count chips -->
  <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-5">
    <div class="p-3 bg-surface-50 dark:bg-muted-800 border border-surface-200 dark:border-muted-700 rounded-card">
      <p class="text-xs uppercase tracking-caption font-medium text-muted-500 dark:text-muted-400 mb-1">Channels</p>
      <p class="text-2xl font-bold font-mono <%= softDeleteCounts.channels === 0 ? 'text-muted-300 dark:text-muted-600' : 'text-muted-900 dark:text-muted-100' %>"><%= softDeleteCounts.channels %></p>
    </div>
    <div class="p-3 bg-surface-50 dark:bg-muted-800 border border-surface-200 dark:border-muted-700 rounded-card">
      <p class="text-xs uppercase tracking-caption font-medium text-muted-500 dark:text-muted-400 mb-1">Signals</p>
      <p class="text-2xl font-bold font-mono <%= softDeleteCounts.signals === 0 ? 'text-muted-300 dark:text-muted-600' : 'text-muted-900 dark:text-muted-100' %>"><%= softDeleteCounts.signals %></p>
    </div>
    <div class="p-3 bg-surface-50 dark:bg-muted-800 border border-surface-200 dark:border-muted-700 rounded-card">
      <p class="text-xs uppercase tracking-caption font-medium text-muted-500 dark:text-muted-400 mb-1">Entity Mentions</p>
      <p class="text-2xl font-bold font-mono <%= softDeleteCounts.mentions === 0 ? 'text-muted-300 dark:text-muted-600' : 'text-muted-900 dark:text-muted-100' %>"><%= softDeleteCounts.mentions %></p>
    </div>
    <div class="p-3 bg-surface-50 dark:bg-muted-800 border border-surface-200 dark:border-muted-700 rounded-card">
      <p class="text-xs uppercase tracking-caption font-medium text-muted-500 dark:text-muted-400 mb-1">Chat Rows</p>
      <p class="text-2xl font-bold font-mono <%= softDeleteCounts.chats === 0 ? 'text-muted-300 dark:text-muted-600' : 'text-muted-900 dark:text-muted-100' %>"><%= softDeleteCounts.chats %></p>
    </div>
    <div class="p-3 bg-surface-50 dark:bg-muted-800 border border-surface-200 dark:border-muted-700 rounded-card">
      <p class="text-xs uppercase tracking-caption font-medium text-muted-500 dark:text-muted-400 mb-1">Poll Progress</p>
      <p class="text-2xl font-bold font-mono <%= softDeleteCounts.progress === 0 ? 'text-muted-300 dark:text-muted-600' : 'text-muted-900 dark:text-muted-100' %>"><%= softDeleteCounts.progress %></p>
    </div>
    <div class="p-3 bg-surface-100 dark:bg-muted-700 border border-surface-300 dark:border-muted-600 rounded-card">
      <p class="text-xs uppercase tracking-caption font-medium text-muted-500 dark:text-muted-400 mb-1">Total</p>
      <p class="text-2xl font-bold font-mono <%= softDeleteTotal === 0 ? 'text-muted-300 dark:text-muted-600' : 'text-muted-900 dark:text-muted-100' %>"><%= softDeleteTotal %></p>
    </div>
  </div>

  <!-- Bulk actions -->
  <div class="flex flex-wrap gap-4 items-start p-4 bg-surface-50 dark:bg-muted-800 border border-surface-200 dark:border-muted-700 rounded-card">
    <div class="flex-1 min-w-0">
      <p class="text-sm font-medium text-muted-800 dark:text-muted-200 mb-0.5">Bulk actions</p>
      <p class="text-xs leading-relaxed text-muted-500 dark:text-muted-400">
        These operations affect all <strong><%= softDeleteTotal %></strong> soft-deleted row<%= softDeleteTotal === 1 ? '' : 's' %> across all tables.
      </p>
    </div>
    <div class="flex gap-2 flex-shrink-0">
      <button type="button"
        <%= softDeleteTotal === 0 ? 'disabled' : '' %>
        class="px-4 py-2 bg-brand-600 text-white rounded-card hover:bg-brand-700 disabled:opacity-50 disabled:cursor-not-allowed text-sm font-medium transition-colors"
        @click="$dispatch('open-delete-modal', {
          title: 'Undo All Soft Deletes?',
          message: 'This will restore <%= softDeleteTotal %> soft-deleted entities across all tables.',
          actionUrl: '/admin/undo-all',
          counts: { channels: <%= softDeleteCounts.channels %>, signals: <%= softDeleteCounts.signals %>, mentions: <%= softDeleteCounts.mentions %>, chats: <%= softDeleteCounts.chats %>, progress: <%= softDeleteCounts.progress %> }
        })">Undo All</button>

      <button type="button"
        <%= softDeleteTotal === 0 ? 'disabled' : '' %>
        class="px-4 py-2 bg-danger-600 text-white rounded-card hover:bg-danger-700 disabled:opacity-50 disabled:cursor-not-allowed text-sm font-medium transition-colors"
        @click="$dispatch('open-delete-modal', {
          title: 'Purge All Soft Deleted?',
          message: 'This will permanently delete <%= softDeleteTotal %> soft-deleted entities. This cannot be undone.',
          actionUrl: '/admin/purge-all',
          counts: { channels: <%= softDeleteCounts.channels %>, signals: <%= softDeleteCounts.signals %>, mentions: <%= softDeleteCounts.mentions %>, chats: <%= softDeleteCounts.chats %>, progress: <%= softDeleteCounts.progress %> }
        })">Purge All</button>
    </div>
  </div>
</div>
