<!-- Topic row partial — 4 columns: Key, Short Name, Channels, Actions -->
<tr class="border-b border-surface-100 dark:border-muted-800" data-topic-id="<%= topic.id %>">
  <!-- Key cell -->
  <td class="py-2 px-3">
    <span class="font-mono text-xs text-muted-800 dark:text-muted-200"><%= topic.key %></span>
  </td>
  <!-- Short Name cell -->
  <td class="py-2 px-3">
    <span class="text-muted-800 dark:text-muted-200"><%= topic.short_name %></span>
  </td>
  <!-- Channels cell (read-only) -->
  <td class="py-2 px-3 text-muted-600 dark:text-muted-300"><%= topic.channel_count || 0 %></td>
  <!-- Actions cell -->
  <td class="py-2 px-3">
    <span class="flex gap-3">
      <button type="button"
        @click="$dispatch('open-topic-modal', { mode: 'edit', topic: { id: <%= topic.id %>, key: <%= JSON.stringify(topic.key) %>, short_name: <%= JSON.stringify(topic.short_name) %>, filter_text: <%= JSON.stringify(topic.filter_text || '') %>, summary_prompt: <%= JSON.stringify(topic.summary_prompt || '') %>, multi_signal_summary_prompt: <%= JSON.stringify(topic.multi_signal_summary_prompt || '') %> } })"
        class="text-brand-600 dark:text-brand-400 hover:text-brand-800 dark:hover:text-brand-200 text-xs focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded">Edit</button>
      <button type="button" @click="deleteAndRemove(<%= topic.id %>, <%= topic.channel_count || 0 %>)" class="text-danger-600 dark:text-danger-400 hover:text-danger-800 dark:hover:text-danger-200 text-xs">Delete</button>
    </span>
  </td>
</tr>