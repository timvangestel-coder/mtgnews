<!-- Topic row partial — used for initial render and HTMX swap after update (Issue #65) -->
<tr class="border-b" data-topic-id="<%= topic.id %>" :class="{ 'bg-blue-50': editId === <%= topic.id %> }" x-show="editId !== <%= topic.id %> || true" @click.outside="if(editId === <%= topic.id %>) editId = null">
  <!-- Key cell -->
  <td class="py-2 px-3">
    <span x-show="editId !== <%= topic.id %>" class="font-mono text-xs"><%= topic.key %></span>
    <input x-cloak x-show="editId === <%= topic.id %>" type="text" name="key" value="<%= topic.key %>"
      class="px-2 py-1 border rounded text-sm font-mono w-full focus:outline-none focus:ring-2 focus:ring-blue-500" required />
  </td>
  <!-- Short Name cell -->
  <td class="py-2 px-3">
    <span x-show="editId !== <%= topic.id %>"><%= topic.short_name %></span>
    <input x-cloak x-show="editId === <%= topic.id %>" type="text" name="short_name" value="<%= topic.short_name %>"
      class="px-2 py-1 border rounded text-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-500" required />
  </td>
  <!-- Filter Text cell -->
  <td class="py-2 px-3 max-w-[200px]">
    <% var ft = topic.filter_text || ''; %>
    <span x-show="editId !== <%= topic.id %>" title="<%= ft %>"><%= ft.substring(0, 80) %><% if (ft.length > 80) { %>&hellip;<% } %></span>
    <textarea x-cloak x-show="editId === <%= topic.id %>" name="filter_text" rows="2"
      class="px-2 py-1 border rounded text-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-500"><%= ft %></textarea>
  </td>
  <!-- Summary Prompt cell -->
  <td class="py-2 px-3 max-w-[200px]">
    <% var sp = topic.summary_prompt || ''; %>
    <% var spDisplay = sp ? (sp.substring(0, 80) + (sp.length > 80 ? '&hellip;' : '')) : '&#40;using default&#41;'; %>
    <span x-show="editId !== <%= topic.id %>" title="<%= sp || '(using default)' %>"><%- spDisplay %></span>
    <textarea x-cloak x-show="editId === <%= topic.id %>" name="summary_prompt" rows="4"
      class="px-2 py-1 border rounded text-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-500"><%= sp %></textarea>
  </td>
  <!-- Multi-Signal Summary Prompt cell (Issue #137) -->
  <td class="py-2 px-3 max-w-[200px]">
    <% var msp = topic.multi_signal_summary_prompt || ''; %>
    <% var mspDisplay = msp ? (msp.substring(0, 80) + (msp.length > 80 ? '&hellip;' : '')) : '&#40;using default&#41;'; %>
    <span x-show="editId !== <%= topic.id %>" title="<%= msp || '(using default)' %>"><%- mspDisplay %></span>
    <textarea x-cloak x-show="editId === <%= topic.id %>" name="multi_signal_summary_prompt" rows="4"
      class="px-2 py-1 border rounded text-sm w-full focus:outline-none focus:ring-2 focus:ring-blue-500"><%= msp %></textarea>
  </td>
  <!-- Channels cell (read-only) -->
  <td class="py-2 px-3"><%= topic.channel_count || 0 %></td>
  <!-- Actions cell -->
  <td class="py-2 px-3">
    <!-- View mode actions -->
    <span x-show="editId !== <%= topic.id %>" class="flex gap-3">
      <button type="button" @click="editId = <%= topic.id %>" class="text-blue-600 hover:text-blue-800 text-xs">Edit</button>
      <button type="button" onclick="if(confirm('Delete this topic?<% if ((topic.channel_count || 0) > 0) { %> <%= topic.channel_count %> channel(s) will be unassigned.<% } %>')) window.__topicSubmit(<%= topic.id %>, '/admin/topics/delete')" class="text-red-600 hover:text-red-800 text-xs">Delete</button>
    </span>
    <!-- Edit mode actions -->
    <span x-cloak x-show="editId === <%= topic.id %>" class="flex gap-2">
      <button type="button" onclick="window.__topicSubmit(<%= topic.id %>, '/admin/topics/update')" class="px-3 py-1 bg-green-600 text-white rounded text-sm hover:bg-green-700">Save</button>
      <button type="button" @click.prevent="editId = null" class="px-3 py-1 bg-gray-300 rounded text-sm hover:bg-gray-400">Cancel</button>
    </span>
  </td>
</tr>