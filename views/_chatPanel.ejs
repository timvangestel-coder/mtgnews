<%
var isMulti = isMultiSignal === true;
var toggleDataAttr = isMulti ? 'data-signals-chat-toggle' : 'data-chat-toggle';
var panelDataAttr = isMulti ? 'data-signals-chat-panel' : 'data-chat-panel';
var inputDataAttr = isMulti ? 'data-signals-chat-input' : 'data-chat-input';
var sendDataAttr = isMulti ? 'data-signals-chat-send' : 'data-chat-send';
var historyContentId = isMulti ? 'signals-chat-history-content' : 'chat-history-content';
var messagesListId = isMulti ? 'signals-chat-messages-list' : 'chat-messages-list';
%>

<div x-data="chatPanel({
  hasVideoId: <%= isMulti === false %>,
  <% if (isMulti) { %>
  topicKey: '<%= ((scope && scope.topicKey) || '').replace(/'/g, "\\'") %>',
  channelId: '<%= ((scope && scope.channelId) || '').replace(/'/g, "\\'") %>',
  showIrrelevant: <%= (scope && typeof scope.showIrrelevant === 'boolean') ? scope.showIrrelevant : 'false' %>,
  signalCount: <%= (scope && scope.signalCount) ? scope.signalCount : '0' %>,
  channelsMap: <%= JSON.stringify((scope && scope.channelsMap) || {}) %>
  <% } else { %>
  videoId: '<%= ((scope && scope.videoId) || '').replace(/'/g, "\\'") %>'
  <% } %>
})"
 data-chat-endpoint="/chat/ask"
 data-history-endpoint="/chat/history"
 data-status-endpoint="/chat/"
 data-filter-event="htmx:afterRequest">

  <% if (isMulti) { %>
  <div data-scope-toast x-show="toastVisible" x-transition.opacity.duration.300ms class="fixed right-6 top-20 z-50 bg-success-500 text-white px-4 py-2 rounded-card shadow-panel-lg text-sm font-medium" x-text="toastMessage"></div>
  <% } %>

  <!-- Floating toggle button -->
  <button <%= toggleDataAttr %> x-show="!chatOpen" @click="toggleChat" type="button"
          aria-label="Toggle AI Assistant chat panel"
          class="fixed right-6 top-6 z-50 bg-brand-500 hover:bg-brand-600 text-white rounded-full shadow-panel-lg transition-colors w-12 h-12 flex items-center justify-center focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
          title="Toggle AI Assistant">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
  </button>

  <!-- Chat panel -->
  <div <%= panelDataAttr %>
       x-show="chatOpen"
       x-trap.focusable="chatOpen"
       @keydown.escape.window="chatOpen && closeChat()"
       role="dialog"
       aria-modal="true"
       aria-label="AI Assistant chat"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="translate-x-full opacity-0"
       x-transition:enter-end="translate-x-0 opacity-100"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="translate-x-0 opacity-100"
       x-transition:leave-end="translate-x-full opacity-0"
       :class="chatOpen ? 'pointer-events-auto' : 'pointer-events-none'"
       class="fixed right-0 top-0 z-40 h-full w-full md:w-[760px] max-w-full bg-white dark:bg-slate-800 shadow-panel-lg flex flex-col rounded-l-xl overflow-hidden">

    <!-- Gradient header -->
    <div class="bg-gradient-to-r from-brand-500 to-purple-500 px-4 py-3 flex items-center justify-between shrink-0">
      <div class="flex items-center gap-2">
        <!-- Heading level: panel title -->
        <h3 class="text-lg font-semibold tracking-heading text-white">AI Assistant</h3>
        <% if (isMulti) { %>
        <!-- Caption level: scope badge -->
        <span data-scope-badge class="text-xs tracking-caption bg-white/20 text-white px-2 py-0.5 rounded-pill" x-text="scopeLabel"></span>
        <% } %>
      </div>
      <button @click="closeChat" type="button"
              class="text-white/80 hover:text-white transition-colors p-1 rounded-lg hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-white"
              aria-label="Close chat panel">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </div>

    <!-- Messages area -->
    <div id="<%= messagesListId %>" class="flex-1 overflow-y-auto p-4 space-y-3"><div id="<%= historyContentId %>"></div></div>

    <!-- Input bar -->
    <div class="border-t border-surface-200 dark:border-muted-700 p-3 shrink-0 bg-white dark:bg-slate-800">
      <form @submit.prevent="sendQuestion" class="flex gap-2 items-end">
        <!-- Body level: input + button -->
        <textarea <%= inputDataAttr %> x-model="chatInput" placeholder="<%= isMulti ? 'Ask a question about these signals...' : 'Ask a question...' %>" rows="2" @keydown.enter.ctrl.prevent="sendQuestion" @keydown.enter.meta.prevent="sendQuestion" class="flex-1 border border-surface-200 dark:border-muted-600 rounded-input px-3 py-2 text-sm leading-relaxed focus:outline-none focus:ring-2 focus:ring-brand-500 resize-none bg-white dark:bg-slate-700 text-muted-800 dark:text-muted-100 min-h-[60px] field-sizing-content"></textarea>
        <button <%= sendDataAttr %> type="submit"
                class="bg-brand-500 hover:bg-brand-600 text-white rounded-input px-4 py-2 text-sm font-medium transition-colors flex items-center justify-center shrink-0 self-stretch focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
                aria-label="Send message">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" /></svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Backdrop -->
  <div <% if (isMulti) { %>data-signals-chat-backdrop<% } %> x-show="chatOpen" x-transition.opacity @click="closeChat" :class="chatOpen ? 'pointer-events-auto' : 'pointer-events-none'" class="fixed inset-0 z-30 bg-black/20 dark:bg-black/50"></div>
</div>