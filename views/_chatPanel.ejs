<%
var isMulti = isMultiSignal === true;
var toggleDataAttr = isMulti ? 'data-signals-chat-toggle' : 'data-chat-toggle';
var panelDataAttr = isMulti ? 'data-signals-chat-panel' : 'data-chat-panel';
var inputDataAttr = isMulti ? 'data-signals-chat-input' : 'data-chat-input';
var sendDataAttr = isMulti ? 'data-signals-chat-send' : 'data-chat-send';
var historyContentId = isMulti ? 'signals-chat-history-content' : 'chat-history-content';
var messagesListId = isMulti ? 'signals-chat-messages-list' : 'chat-messages-list';
%>

<div x-data="chatPanel({
  hasVideoId: <%= isMulti === false %>,
  <% if (isMulti) { %>
  topicKey: '<%= ((scope && scope.topicKey) || '').replace(/'/g, "\\'") %>',
  channelId: '<%= ((scope && scope.channelId) || '').replace(/'/g, "\\'") %>',
  showIrrelevant: <%= (scope && typeof scope.showIrrelevant === 'boolean') ? scope.showIrrelevant : 'false' %>,
  signalCount: <%= (scope && scope.signalCount) ? scope.signalCount : '0' %>,
  channelsMap: <%= JSON.stringify((scope && scope.channelsMap) || {}) %>
  <% } else { %>
  videoId: '<%= ((scope && scope.videoId) || '').replace(/'/g, "\\'") %>'
  <% } %>
})"
 data-chat-endpoint="/chat/ask"
 data-history-endpoint="/chat/history"
 data-status-endpoint="/chat/"
 data-filter-event="htmx:afterRequest">

  <% if (isMulti) { %>
  <div data-scope-toast x-show="toastVisible" x-transition.opacity.duration.300ms class="fixed right-6 top-20 z-50 bg-green-600 text-white px-4 py-2 rounded-lg shadow-lg text-sm font-medium" x-text="toastMessage"></div>
  <% } %>

  <button <%= toggleDataAttr %> x-show="!chatOpen" @click="toggleChat" type="button" class="fixed right-6 top-6 z-50 bg-indigo-600 hover:bg-indigo-700 text-white rounded-full shadow-lg transition-colors w-12 h-12 flex items-center justify-center" title="Toggle chat">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
  </button>

  <div <%= panelDataAttr %> x-show="chatOpen" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="translate-x-full opacity-0" x-transition:enter-end="translate-x-0 opacity-100" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="translate-x-0 opacity-100" x-transition:leave-end="translate-x-full opacity-0" :class="chatOpen ? 'pointer-events-auto' : 'pointer-events-none'" class="fixed right-0 top-0 z-40 h-full w-[760px] max-w-full bg-white shadow-2xl flex flex-col border-l border-gray-200">
    <div class="flex items-center justify-between px-4 py-3 border-b border-gray-200">
      <div>
        <h3 class="font-semibold text-gray-800">Chat</h3>
        <% if (isMulti) { %><span data-scope-badge class="text-xs text-gray-500" x-text="scopeLabel"></span><% } %>
      </div>
      <button @click="toggleChat" type="button" class="text-gray-500 hover:text-gray-700"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg></button>
    </div>
    <div id="<%= messagesListId %>" class="flex-1 overflow-y-auto p-4 space-y-3"><div id="<%= historyContentId %>"></div></div>
    <div class="border-t border-gray-200 p-3">
       <form @submit.prevent="sendQuestion" class="flex gap-2 items-end">
         <textarea <%= inputDataAttr %> x-model="chatInput" placeholder="<%= isMulti ? 'Ask a question about these signals...' : 'Ask a question...' %>" rows="2" @keydown.enter.ctrl.prevent="sendQuestion" @keydown.enter.meta.prevent="sendQuestion" class="flex-1 border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 resize-none min-h-[60px]" style="field-sizing: content;"></textarea>
         <button <%= sendDataAttr %> type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg px-4 py-2 text-sm font-medium transition-colors">Send</button>
       </form>
    </div>
  </div>

  <div <% if (isMulti) { %>data-signals-chat-backdrop<% } %> x-show="chatOpen" x-transition.opacity @click="toggleChat" :class="chatOpen ? 'pointer-events-auto' : 'pointer-events-none'" class="fixed inset-0 z-30 bg-black/20"></div>
</div>
