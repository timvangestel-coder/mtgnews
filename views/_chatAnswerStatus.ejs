<!-- Status endpoint: returns a chat-answer-bubble div on every response. -->
<!-- Structure matches _chatHistory.ejs so polling swaps are seamless. -->
<% if (status === 'failed') { %>
<div class="flex items-start gap-2 justify-end chat-answer-bubble mt-1">
  <div class="bg-brand-50 dark:bg-slate-600 rounded-xl rounded-tr-sm px-3 py-2 shadow-sm max-w-[85%]">
    <p class="text-sm text-danger-600 dark:text-danger-400 font-medium">Response failed</p>
  </div>
  <div class="w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">AI</div>
</div>
<% } else if (status === 'pending') { %>
<%
  var phaseLabel = 'processing...';
  if (typeof phase !== 'undefined') {
    if (phase === 'intake') phaseLabel = 'Intaking...';
    else if (phase === 'reasoning') phaseLabel = 'Reasoning...' + (typeof tokenCount !== 'undefined' && tokenCount > 0 ? ' (' + tokenCount + ' tokens)' : '');
    else if (phase === 'answering') phaseLabel = 'Answering...' + (typeof tokenCount !== 'undefined' && tokenCount > 0 ? ' (' + tokenCount + ' tokens)' : '');
    else if (phase === 'retrieving') phaseLabel = 'Retrieving context...';
    else if (phase === 'done') phaseLabel = 'Done';
  }
%>
<div class="flex items-start gap-2 justify-end chat-answer-bubble mt-1">
  <div class="bg-brand-50 dark:bg-slate-600 rounded-xl rounded-tr-sm px-3 py-2 shadow-sm max-w-[85%]">
    <div class="chat-phase-container" data-chat-phase="<%= typeof phase !== 'undefined' ? phase : '' %>" data-chat-token-count="<%= typeof tokenCount !== 'undefined' ? tokenCount : 0 %>" data-chat-round="<%= typeof round !== 'undefined' ? round : 1 %>">
      <!-- Bouncing dots typing indicator -->
      <div class="flex items-center gap-1 typing-dots-indicator">
        <span class="w-2 h-2 bg-brand-400 dark:bg-brand-300 rounded-full animate-bounce typing-dot-1"></span>
        <span class="w-2 h-2 bg-brand-400 dark:bg-brand-300 rounded-full animate-bounce typing-dot-2"></span>
        <span class="w-2 h-2 bg-brand-400 dark:bg-brand-300 rounded-full animate-bounce typing-dot-3"></span>
      </div>
      <span class="chat-phase-text text-xs text-muted-400 dark:text-muted-500 mt-1 block phase-micro-label"><%= phaseLabel %></span>
      <% if (typeof round !== 'undefined' && round > 1) { %>
      <span class="text-xs text-muted-300 dark:text-muted-600 ml-1 chat-round-indicator">(Round <%= round %>)</span>
      <% } %>
    </div>
  </div>
  <div class="w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">AI</div>
</div>
<% } else { %>
<div class="flex items-start gap-2 justify-end chat-answer-bubble mt-1">
  <div class="bg-brand-50 dark:bg-slate-600 rounded-xl rounded-tr-sm px-3 py-2 shadow-sm max-w-[85%]">
    <div class="chat-answer text-sm text-gray-800 dark:text-gray-100">
      <%- answer %>
    </div>
  </div>
  <div class="w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">AI</div>
</div>
<% } %>