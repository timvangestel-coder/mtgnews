<!-- Display level: page title -->
<h2 class="text-2xl font-bold tracking-display text-muted-900 dark:text-muted-100 mb-4">Run History</h2>

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-surface-200 dark:divide-muted-700">
    <thead class="bg-surface-50 dark:bg-muted-800">
      <tr>
        <!-- Caption level: table headers -->
        <th class="px-4 py-2 text-left text-xs tracking-caption font-medium text-muted-500 dark:text-muted-400 uppercase">Date / Time</th>
        <th class="px-4 py-2 text-left text-xs tracking-caption font-medium text-muted-500 dark:text-muted-400 uppercase">Status</th>
        <th class="px-4 py-2 text-left text-xs tracking-caption font-medium text-muted-500 dark:text-muted-400 uppercase">Lookback</th>
        <th class="px-4 py-2 text-left text-xs tracking-caption font-medium text-muted-500 dark:text-muted-400 uppercase">New Signals</th>
        <th class="px-4 py-2 text-left text-xs tracking-caption font-medium text-muted-500 dark:text-muted-400 uppercase">Channels</th>
        <th class="px-4 py-2 text-left text-xs tracking-caption font-medium text-muted-500 dark:text-muted-400 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white dark:bg-slate-800 divide-y divide-surface-200 dark:divide-muted-700">
      <% runs.forEach(function(run) { %>
        <tr class="hover:bg-surface-50 dark:hover:bg-slate-700 cursor-pointer" onclick="window.location.href='/polls/<%= run.id %>-detail'">
          <!-- Body level: table cells -->
          <td class="px-4 py-2 whitespace-nowrap text-sm leading-relaxed text-muted-800 dark:text-muted-200">
            <%= new Date(run.triggered_at).toLocaleString() %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm">
            <% if (run.status === 'done') { %>
              <!-- Caption level: status badges -->
              <span class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-success-600 rounded">done</span>
            <% } else if (run.status === 'done-forced') { %>
              <span class="px-2 py-1 text-xs tracking-caption font-semibold text-warning-800 bg-warning-100 dark:bg-warning-900 dark:text-warning-200 rounded">done-forced</span>
            <% } else if (run.status === 'failed') { %>
              <span class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-danger-600 rounded">failed</span>
            <% } else { %>
              <span class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-warning-500 rounded">running</span>
            <% } %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm leading-relaxed text-muted-800 dark:text-muted-200">
            <%= run.lookback_days %>d
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm leading-relaxed text-muted-800 dark:text-muted-200">
            <%= run.new_signal_count %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm leading-relaxed text-muted-800 dark:text-muted-200">
            <%= run.channels_done %>/<%= run.channels_total %> done<% if (run.channels_failed > 0) { %>, <%= run.channels_failed %> failed<% } %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm" onclick="event.stopPropagation()">
            <% if (run.status === 'running') { %>
              <form action="/admin/poll/abort/<%= run.id %>?return_to=/polls" method="post" class="inline">
                <!-- Caption level: action button -->
                <button type="submit" class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-danger-600 rounded hover:bg-danger-700">Abort</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<% if (totalPages > 1) { %>
  <!-- Pagination — Body level with vertical rhythm -->
  <div class="flex justify-between items-center mt-4 pt-4 border-t border-surface-200 dark:border-muted-700">
    <% if (page > 1) { %>
      <a href="/polls?page=<%= page - 1 %>" class="px-3 py-1 bg-brand-600 text-white rounded-card hover:bg-brand-700 text-sm leading-relaxed transition">Previous</a>
    <% } else { %>
      <span></span>
    <% } %>
    <!-- Caption level: page info -->
    <span class="text-xs tracking-caption text-muted-500 dark:text-muted-400">Page <%= page %> of <%= totalPages %></span>
    <% if (page < totalPages) { %>
      <a href="/polls?page=<%= page + 1 %>" class="px-3 py-1 bg-brand-600 text-white rounded-card hover:bg-brand-700 text-sm leading-relaxed transition">Next</a>
    <% } else { %>
      <span></span>
    <% } %>
  </div>
<% } %>

<% if (runs.length === 0) { %>
  <!-- Body level: empty state -->
  <p class="text-sm leading-relaxed text-muted-500 dark:text-muted-400 mt-4">No poll runs yet.</p>
<% } %>