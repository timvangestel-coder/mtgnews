<h2 class="text-2xl font-bold mb-4">Run History</h2>

<div class="overflow-x-auto">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Date / Time</th>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">New Signals</th>
        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Channels</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% runs.forEach(function(run) { %>
        <tr class="hover:bg-gray-50 cursor-pointer" onclick="window.location.href='/polls/<%= run.id %>-detail'">
          <td class="px-4 py-2 whitespace-nowrap text-sm">
            <%= new Date(run.triggered_at).toLocaleString() %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm">
            <% if (run.status === 'done') { %>
              <span class="px-2 py-1 text-xs font-semibold text-white bg-green-600 rounded">done</span>
            <% } else if (run.status === 'failed') { %>
              <span class="px-2 py-1 text-xs font-semibold text-white bg-red-600 rounded">failed</span>
            <% } else { %>
              <span class="px-2 py-1 text-xs font-semibold text-white bg-amber-500 rounded">running</span>
            <% } %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm">
            <%= run.new_signal_count %>
          </td>
          <td class="px-4 py-2 whitespace-nowrap text-sm">
            <%= run.channels_done %>/<%= run.channels_total %> done<% if (run.channels_failed > 0) { %>, <%= run.channels_failed %> failed<% } %>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<% if (totalPages > 1) { %>
  <div class="flex justify-between items-center mt-4">
    <% if (page > 1) { %>
      <a href="/polls?page=<%= page - 1 %>" class="px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700">Previous</a>
    <% } else { %>
      <span></span>
    <% } %>
    <span class="text-sm text-gray-600">Page <%= page %> of <%= totalPages %></span>
    <% if (page < totalPages) { %>
      <a href="/polls?page=<%= page + 1 %>" class="px-3 py-1 bg-blue-600 text-white rounded hover:bg-blue-700">Next</a>
    <% } else { %>
      <span></span>
    <% } %>
  </div>
<% } %>

<% if (runs.length === 0) { %>
  <p class="text-gray-500 mt-4">No poll runs yet.</p>
<% } %>