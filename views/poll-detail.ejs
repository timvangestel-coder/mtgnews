<!-- Display level: page title -->
<h2 class="text-2xl font-bold tracking-display text-muted-900 dark:text-muted-100 mb-4">Run Detail</h2>

<!-- Body level: detail summary with vertical rhythm -->
<div class="mb-6 space-y-2">
  <div class="flex items-center gap-4">
    <div>
      <!-- Caption label + Heading value -->
      <span class="text-xs tracking-caption text-muted-500 dark:text-muted-400">Triggered</span>
      <p class="text-lg font-semibold tracking-heading text-muted-900 dark:text-muted-100"><%= new Date(run.triggered_at).toLocaleString() %></p>
    </div>
    <div>
      <% if (run.status === 'done') { %>
        <!-- Caption level: status badge -->
        <span class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-success-600 rounded-card">done</span>
      <% } else if (run.status === 'done-forced') { %>
        <span class="px-2 py-1 text-xs tracking-caption font-semibold text-warning-800 bg-warning-100 dark:bg-warning-900 dark:text-warning-200 rounded-card">done-forced</span>
      <% } else if (run.status === 'failed') { %>
        <span class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-danger-600 rounded-card">failed</span>
      <% } else { %>
        <span class="px-2 py-1 text-xs tracking-caption font-semibold text-white bg-warning-500 rounded-card">running</span>
      <% } %>
    </div>
    <div>
      <!-- Caption label + Heading value -->
      <span class="text-xs tracking-caption text-muted-500 dark:text-muted-400">New Signals</span>
      <p class="text-lg font-semibold tracking-heading text-muted-900 dark:text-muted-100"><%= run.new_signal_count %></p>
    </div>
  </div>

</div>

<%- include('admin/_pollProgress', { state: state, progressUrl: '/polls/' + run.id + '/progress' }) %>

<!-- Body level: back link -->
<div class="mt-6 pt-4 border-t border-surface-200 dark:border-muted-700">
  <a href="/polls" class="text-sm leading-relaxed text-brand-600 dark:text-brand-400 hover:underline">&larr; Back to Run History</a>
</div>