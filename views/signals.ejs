<h2 class="text-2xl font-bold mb-4">Signals</h2>

<!-- Topic + Channel Filter Pills + Date Filter + Show Irrelevant Toggle -->
<div class="mb-4 flex flex-col gap-3"
     x-data="{
      topics: <%= JSON.stringify(topics || []) %>,
      channels: <%= JSON.stringify(channels || []) %>,
      selectedTopic: '<%= (topicKey || '').replace(/'/g, "\\'") %>',
      selectedChannel: '<%= (channelId || '').replace(/'/g, "\\'") %>',
      showIrrelevant: <%= typeof showIrrelevant === 'boolean' ? showIrrelevant : 'false' %>,
      dateFilter: '<%= (dateFilter || '').replace(/'/g, "\\'") %>',
      get filteredChannels() {
        return this.selectedTopic
          ? this.channels.filter(c => c.topic_key === this.selectedTopic)
          : this.channels;
      },
      _buildUrl(forAjax) {
        var params = new URLSearchParams();
        if (this.selectedTopic) params.set('topicKey', this.selectedTopic);
        else params.set('topicKey', '');
        if (this.selectedChannel) params.set('channelId', this.selectedChannel);
        else params.set('channelId', '');
        if (this.showIrrelevant) params.set('showIrrelevant', 'true');
        if (this.dateFilter && this.dateFilter !== '') params.set('dateFilter', this.dateFilter);
        var url = '/signals?' + params.toString();
        window.history.pushState({}, '', url);
        if (forAjax) {
          params.set('htmx', 'true');
          return '/signals?' + params.toString();
        }
        return url;
      },
      selectTopic(key) {
        this.selectedTopic = key;
        this.selectedChannel = '';
        $nextTick(() => {
          htmx.ajax('GET', this._buildUrl(true), { target: '#signals-table' });
        });
      },
      selectChannel(id) {
        this.selectedChannel = id;
        $nextTick(() => {
          htmx.ajax('GET', this._buildUrl(true), { target: '#signals-table' });
        });
      },
      setDateFilter(filter) {
        this.dateFilter = filter;
        $nextTick(() => {
          htmx.ajax('GET', this._buildUrl(true), { target: '#signals-table' });
        });
      }
    }">

  <!-- Row 1: Topic Pills + Date Filter -->
  <div class="flex flex-wrap gap-2 items-center">
    <button class="rounded-full px-4 py-1 text-sm transition"
            :class="selectedTopic === '' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
            @click="selectTopic('')">
      All Topics
    </button>
    <template x-for="topic in topics" :key="topic.key">
      <button class="rounded-full px-4 py-1 text-sm transition"
              :class="selectedTopic === topic.key ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
              @click="selectTopic(topic.key)"
              x-text="topic.short_name || topic.key">
      </button>
    </template>

    <!-- Date Filter Pills (Issue #181) -->
    <div class="flex gap-2 ml-4">
      <button class="rounded-full px-3 py-1 text-sm transition"
              :class="(!dateFilter || dateFilter === '') ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700'"
              @click="setDateFilter('')">
        All Time
      </button>
      <button class="rounded-full px-3 py-1 text-sm transition"
              :class="dateFilter === 'today' ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700'"
              @click="setDateFilter('today')">
        Today
      </button>
      <button class="rounded-full px-3 py-1 text-sm transition"
              :class="dateFilter === 'week' ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700'"
              @click="setDateFilter('week')">
        This Week
      </button>
      <button class="rounded-full px-3 py-1 text-sm transition"
              :class="dateFilter === 'month' ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700'"
              @click="setDateFilter('month')">
        This Month
      </button>
    </div>

    <!-- Show Irrelevant Toggle -->
    <div class="ml-auto">
      <button class="rounded-full px-4 py-1 text-sm transition"
              :class="showIrrelevant ? 'bg-orange-500 text-white' : 'bg-gray-200 text-gray-700'"
              @click="showIrrelevant = !showIrrelevant; $nextTick(() => { htmx.ajax('GET', _buildUrl(true), { target: '#signals-table' }); })">
        Show Irrelevant
      </button>
    </div>
  </div>

  <!-- Row 2: Channel Pills -->
  <div class="flex flex-wrap gap-2 items-center">
    <button class="rounded-full px-4 py-1 text-sm transition"
            :class="selectedChannel === '' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
            @click="selectChannel('')">
      All Channels
    </button>
    <template x-for="ch in filteredChannels" :key="ch.channel_id">
      <button class="rounded-full px-4 py-1 text-sm transition"
              :class="selectedChannel === ch.channel_id ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
              @click="selectChannel(ch.channel_id)"
              x-text="ch.display_name || ch.channel_id">
      </button>
    </template>
  </div>
</div>

 <!-- Signal Table Fragment -->
 <div id="signals-table">
   <%- include('_signalsTable', { signals, page, totalPages, total, channelId, topicKey, showIrrelevant, dateFilter }) %>
 </div>

 <% var chatScope = { topicKey: topicKey, channelId: channelId, showIrrelevant: showIrrelevant, signalCount: total, channelsMap: channelsMap, dateFilter: dateFilter }; %>
<%- include('_chatPanel', { scope: chatScope, isMultiSignal: true, hasVideoId: false }) %>

<!-- TimestampNav pass-through mode: timestamp links navigate to Signal Detail page -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    if (window.TimestampNav) {
      window.TimestampNav.init({ samePage: false });
    }
  });
</script>