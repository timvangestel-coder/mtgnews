<div class="max-w-3xl relative"
     style="margin-left: max(0px, calc(50vw - 664px)); margin-right: auto;"
     data-video-id="<%= signal.video_id %>"
     x-data="UiState.detailTabs('summary')">

  <!-- Error flash message -->
  <% if (error) { %>
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
      <%= decodeURIComponent(error) %>
    </div>
  <% } %>

  <!-- Card container -->
  <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-200 dark:border-slate-700 p-4 shadow-card-md">

    <!-- Header: Signal title + channel pill badge -->
    <div class="mb-4">
      <div class="flex items-start justify-between gap-3">
        <div class="min-w-0">
          <!-- Display level: page title -->
          <h2 class="text-2xl font-bold tracking-display text-muted-900 dark:text-muted-100 mb-2"><%= title %></h2>
          <!-- Caption level: metadata -->
          <div class="flex items-center gap-3 text-xs tracking-caption text-muted-500 dark:text-muted-400 flex-wrap">
            <% if (channel) { %>
              <span class="bg-brand-100 dark:bg-brand-900 text-brand-700 dark:text-brand-300 text-xs font-semibold px-2.5 py-0.5 rounded-pill">
                <%= channel.display_name %>
              </span>
            <% } %>
            <% if (signal.published_at) { %>
              <time><%= new Date(signal.published_at).toLocaleString() %><% if (signal.generated_title && originalTitle) { %> - <%= originalTitle %><% } %></time>
            <% } %>
          </div>
        </div>

        <!-- Kebab menu for action buttons -->
        <div class="relative" x-data="{ openMenu: false }">
          <button @click="openMenu = !openMenu" @click.outside="openMenu = false" @keydown.escape.window="openMenu = false"
                  class="p-2 rounded-lg text-muted-400 hover:text-muted-600 dark:text-muted-500 dark:hover:text-muted-300 hover:bg-surface-100 dark:hover:bg-slate-700 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
                  aria-label="Actions menu" :aria-expanded="openMenu.toString()" aria-haspopup="true">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 12.75a.75.75 0 110-1.5.75.75 0 010 1.5zM12 18.75a.75.75 0 110-1.5.75.75 0 010 1.5z" />
            </svg>
          </button>

          <div x-show="openMenu"
               x-transition:enter="transition ease-out duration-100"
               x-transition:enter-start="opacity-0 scale-95"
               x-transition:enter-end="opacity-100 scale-100"
               x-transition:leave="transition ease-in duration-75"
               x-transition:leave-start="opacity-100 scale-100"
               x-transition:leave-end="opacity-0 scale-95"
               class="absolute right-0 mt-2 w-48 bg-white dark:bg-slate-700 rounded-lg shadow-panel-lg border border-surface-200 dark:border-muted-600 py-1 z-20">

            <!-- Mark as Irrelevant -->
            <div id="irrelevant-toggle">
              <% if (signal.processing_state === 'irrelevant') { %>
                <button hx-post="/signals/<%= signal.video_id %>/irrelevant"
                        hx-vals='{"irrelevant": "false"}'
                        hx-swap="outerHTML"
                        @click="openMenu = false"
                        class="w-full text-left px-4 py-2 text-sm text-muted-700 dark:text-muted-200 hover:bg-surface-100 dark:hover:bg-slate-600 transition">
                  Remove Irrelevant <span class="text-danger-500">&times;</span>
                </button>
              <% } else { %>
                <button hx-post="/signals/<%= signal.video_id %>/irrelevant"
                        hx-vals='{"irrelevant": "true"}'
                        hx-swap="outerHTML"
                        @click="openMenu = false"
                        class="w-full text-left px-4 py-2 text-sm text-warning-700 dark:text-warning-300 hover:bg-surface-100 dark:hover:bg-slate-600 transition">
                  Mark as Irrelevant
                </button>
              <% } %>
            </div>

            <!-- Reviewed status -->
            <div id="reviewed-status">
              <% if (signal.reviewed) { %>
                <button hx-post="/signals/<%= signal.video_id %>/reviewed"
                        hx-vals='{"reviewed": "false"}'
                        hx-swap="outerHTML"
                        @click="openMenu = false"
                        class="w-full text-left px-4 py-2 text-sm text-muted-700 dark:text-muted-200 hover:bg-surface-100 dark:hover:bg-slate-600 transition">
                  Remove Reviewed <span class="text-success-500">&#x2713;</span>
                </button>
              <% } else { %>
                <button hx-post="/signals/<%= signal.video_id %>/reviewed"
                        hx-vals='{"reviewed": "true"}'
                        hx-swap="outerHTML"
                        @click="openMenu = false"
                        class="w-full text-left px-4 py-2 text-sm text-brand-600 dark:text-brand-400 hover:bg-surface-100 dark:hover:bg-slate-600 transition">
                  Mark as Reviewed
                </button>
              <% } %>
            </div>

            <% if (!signal.processed_at) { %>
              <div class="border-t border-surface-200 dark:border-muted-600 my-1"></div>
              <form method="post" action="/signals/<%= signal.video_id %>/summarize">
                <button type="submit"
                        @click="openMenu = false"
                        class="w-full text-left px-4 py-2 text-sm text-brand-600 dark:text-brand-400 font-semibold hover:bg-surface-100 dark:hover:bg-slate-600 transition">
                  Summarize
                </button>
              </form>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <!-- Underline tab navigation -->
    <div class="border-b border-surface-200 dark:border-muted-700 mb-4">
      <div role="tablist" aria-label="Signal detail view mode" class="flex gap-0 -mb-px">
        <button id="tab-summary"
                role="tab"
                :aria-selected="viewState === 'summary' ? 'true' : 'false'"
                aria-controls="summary-pane"
                tabindex="0"
                @click="setViewState('summary')"
                @keydown.left.prevent="moveTabFocus('left')"
                @keydown.right.prevent="moveTabFocus('right')"
                :class="viewState === 'summary'
                  ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                  : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200'"
                class="pb-3 px-1 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
          Summary
        </button>
        <button id="tab-transcript"
                role="tab"
                :aria-selected="viewState === 'transcript' ? 'true' : 'false'"
                aria-controls="transcript-pane"
                tabindex="-1"
                @click="setViewState('transcript')"
                @keydown.left.prevent="moveTabFocus('left')"
                @keydown.right.prevent="moveTabFocus('right')"
                :class="viewState === 'transcript'
                  ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                  : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200'"
                class="pb-3 px-1 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
          Transcript
        </button>
        <button id="tab-split"
                role="tab"
                :aria-selected="viewState === 'split' ? 'true' : 'false'"
                aria-controls="summary-pane transcript-pane"
                tabindex="-1"
                @click="setViewState('split')"
                @keydown.left.prevent="moveTabFocus('left')"
                @keydown.right.prevent="moveTabFocus('right')"
                :class="viewState === 'split'
                  ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                  : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200'"
                class="pb-3 px-1 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
          Split
        </button>
      </div>
    </div>

    <!-- Three-state content area -->
    <div class="flex flex-col signal-detail-main overflow-hidden">

      <!-- Summary panel -->
      <div
        id="summary-pane"
        role="tabpanel"
        aria-labelledby="tab-summary"
        class="overflow-y-auto transition-all duration-1000 ease-in-out"
        :class="{
          'flex-[1_1_auto]': viewState === 'summary',
          'flex-[0_0_30%]': viewState === 'split',
          'flex-[0_0_0] overflow-hidden min-h-0': viewState === 'transcript'
        }"
      >
        <% if (summaryHtml) { %>
          <div class="p-4" :class="viewState === 'split' ? 'bg-white dark:bg-slate-800 border-b border-slate-200 dark:border-slate-600' : ''">
            <!-- Heading level: section header with TTS speaker button -->
            <div class="flex items-center justify-between mb-3"
              :class="viewState === 'split' ? 'sticky top-0 bg-white dark:bg-slate-800 z-10 pb-2' : ''"
              x-data="SpeakerButton('<%= signal.video_id %>')"
            >
              <h3 class="text-lg font-semibold tracking-heading text-muted-900 dark:text-muted-100">
                Key Takeaways
              </h3>
              <button @click="click"
                     :disabled="loading"
                     :class="iconClass"
                     class="p-1.5 rounded-lg transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
                     :title="playing ? 'Stop' : 'Listen to summary'"
                     aria-label="Listen to summary">
                <!-- Speaker / stop icon based on state -->
                <svg x-show="idle" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                </svg>
                <svg x-show="loading" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 animate-pulse">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 010 12.728M16.463 8.288a5.25 5.25 0 010 7.424M6.75 8.25l4.72-4.72a.75.75 0 011.28.53v15.88a.75.75 0 01-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.01 9.01 0 012.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75z" />
                </svg>
                <svg x-show="playing" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 6.75a.75.75 0 01.75-.75h9a.75.75 0 01.75.75v10.5a.75.75 0 01-.75.75h-9a.75.75 0 01-.75-.75V6.75z" />
                </svg>
              </button>
            </div>
            <!-- Body level: summary content -->
            <div class="prose prose-sm max-w-none text-sm leading-relaxed text-muted-800 dark:text-muted-200">
              <!-- Brand-colored bullet markers via CSS -->
               <style>
                 #summary-pane ul { list-style: none; padding-left: 1.25rem; }
                 #summary-pane ul li::before {
                   content: '\2022';
                   color: var(--color-brand-600, #4f46e5);
                   font-weight: bold;
                   display: inline-block;
                   width: 1rem;
                   margin-left: -1.25rem;
                 }
                 .dark #summary-pane ul li::before { color: var(--color-brand-400, #818cf8); }
               </style>
              <%- summaryHtml %>
            </div>
          </div>
        <% } %>
      </div>

      <!-- Transcript panel -->
      <div
        id="transcript-pane"
        role="tabpanel"
        aria-labelledby="tab-transcript"
        class="overflow-y-auto transition-all duration-1000 ease-in-out"
        :class="{
          'flex-[1_1_auto]': viewState === 'transcript',
          'flex-[0_0_70%]': viewState === 'split',
          'flex-[0_0_0] overflow-hidden min-h-0': viewState === 'summary'
        }"
      >
        <% if (transcriptionHtml) { %>
          <div class="p-4" :class="viewState === 'split' ? 'bg-surface-50 dark:bg-slate-900' : ''">
            <!-- Heading level: section header -->
            <h3 class="text-lg font-semibold tracking-heading mb-3 text-muted-900 dark:text-muted-100"
              :class="viewState === 'split' ? 'sticky top-0 bg-surface-50 dark:bg-slate-900 z-10 pb-2' : ''"
            >
              Transcription
            </h3>
            <!-- Body level: transcript content -->
            <div class="space-y-1 text-sm leading-relaxed tracking-body text-muted-700 dark:text-muted-300">
              <%- transcriptionHtml %>
            </div>
          </div>
        <% } %>
      </div>

    </div>
  </div>
</div>

<% var detailChatScope = { videoId: signal.video_id }; %>
<!-- Signal Detail Chat Panel — outside outer x-data for independent Alpine lifecycle -->
<%- include('_chatPanel', { scope: detailChatScope, isMultiSignal: false, hasVideoId: true }) %>