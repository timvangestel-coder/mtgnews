<!-- Display level: page title -->
<h2 class="text-2xl font-bold tracking-display text-muted-900 dark:text-muted-100 mb-4">Admin Panel</h2>

<!-- Tab Navigation — UiState.adminTabs() is loaded from /scripts/ui-state.js via layout.ejs -->
<div class="mb-6" x-data="UiState.adminTabs()" data-admin-default-tab="<%= tab || 'overview' %>">
  <!-- Underline tab navigation matching Group A signal-detail pattern -->
  <div class="border-b border-surface-200 dark:border-muted-700 mb-4">
    <div role="tablist" aria-label="Admin panel sections" class="flex flex-wrap gap-0 md:gap-0 -mb-px">
      <button id="admin-tab-overview"
              role="tab"
              :aria-selected="activeTab === 'overview' ? 'true' : 'false'"
              aria-controls="overview-tab-content"
              :tabindex="activeTab === 'overview' ? '0' : '-1'"
              @click="switchTab('overview')"
              @keydown.enter.prevent="switchTab('overview')"
              @keydown.space.prevent="switchTab('overview')"
              @keydown.left.prevent="moveTabFocus('left')"
              @keydown.right.prevent="moveTabFocus('right')"
              :class="activeTab === 'overview'
                ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200 border-b-2 border-transparent'"
              class="pb-3 px-4 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
        Overview
      </button>
      <button id="admin-tab-channels"
              role="tab"
              :aria-selected="activeTab === 'channels' ? 'true' : 'false'"
              aria-controls="channels-tab-content"
              :tabindex="activeTab === 'channels' ? '0' : '-1'"
              @click="switchTab('channels')"
              @keydown.enter.prevent="switchTab('channels')"
              @keydown.space.prevent="switchTab('channels')"
              @keydown.left.prevent="moveTabFocus('left')"
              @keydown.right.prevent="moveTabFocus('right')"
              :class="activeTab === 'channels'
                ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200 border-b-2 border-transparent'"
              class="pb-3 px-4 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
        Channels
      </button>
      <button id="admin-tab-topics"
              role="tab"
              :aria-selected="activeTab === 'topics' ? 'true' : 'false'"
              aria-controls="topics-tab-content"
              :tabindex="activeTab === 'topics' ? '0' : '-1'"
              @click="switchTab('topics')"
              @keydown.enter.prevent="switchTab('topics')"
              @keydown.space.prevent="switchTab('topics')"
              @keydown.left.prevent="moveTabFocus('left')"
              @keydown.right.prevent="moveTabFocus('right')"
              :class="activeTab === 'topics'
                ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200 border-b-2 border-transparent'"
              class="pb-3 px-4 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
        Topics
      </button>
      <button id="admin-tab-settings"
              role="tab"
              :aria-selected="activeTab === 'settings' ? 'true' : 'false'"
              aria-controls="settings-tab-content"
              :tabindex="activeTab === 'settings' ? '0' : '-1'"
              @click="switchTab('settings')"
              @keydown.enter.prevent="switchTab('settings')"
              @keydown.space.prevent="switchTab('settings')"
              @keydown.left.prevent="moveTabFocus('left')"
              @keydown.right.prevent="moveTabFocus('right')"
              :class="activeTab === 'settings'
                ? 'text-brand-600 dark:text-brand-400 border-b-2 border-brand-500 font-semibold'
                : 'text-muted-500 dark:text-muted-400 hover:text-slate-700 dark:hover:text-slate-200 border-b-2 border-transparent'"
              class="pb-3 px-4 text-sm transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 rounded-t">
        Settings
      </button>
    </div>
  </div>

  <!-- Overview Tab -->
  <template x-if="activeTab === 'overview'">
    <div id="overview-tab-content" role="tabpanel" aria-labelledby="admin-tab-overview" x-init="htmx.process($el)">
      <%- include('admin/_overviewTab', { counts: overviewCounts, recentRuns, currentRunState }) %>
    </div>
  </template>

  <!-- Channels Tab -->
  <template x-if="activeTab === 'channels'">
    <div id="channels-tab-content" role="tabpanel" aria-labelledby="admin-tab-channels" x-init="htmx.process($el)">
      <%- include('admin/_channelsTab', { channels, topics }) %>
    </div>
  </template>

  <!-- Topics Tab -->
  <template x-if="activeTab === 'topics'">
    <div id="topics-tab-content" role="tabpanel" aria-labelledby="admin-tab-topics" x-init="htmx.process($el)">
      <%- include('admin/_topicsTab', { topics }) %>
    </div>
  </template>

  <!-- Settings Tab -->
  <template x-if="activeTab === 'settings'">
    <div id="settings-tab-content" role="tabpanel" aria-labelledby="admin-tab-settings" x-init="htmx.process($el)">
      <%- include('admin/_settingsTab', { defaultPrompt, softDeleteCounts, softDeleteTotal }) %>
    </div>
  </template>
</div>

<!-- Delete Confirmation Modal — top-level, reusable from any tab -->
<div x-data="UiState.deleteModal()"
     x-show="open"
     @keydown.escape.window="cancel()"
      class="fixed inset-0 z-50 flex items-center justify-center hidden">
   <!-- Backdrop -->
   <div class="fixed inset-0 bg-black/50" @click="cancel()"></div>

   <!-- Card — p-4 detail padding -->
   <div class="relative bg-white dark:bg-slate-800 rounded-card shadow-panel-lg max-w-md w-full p-4 mx-4 border border-surface-200 dark:border-muted-700">
     <!-- Heading level: modal title -->
     <h3 class="text-lg font-semibold tracking-heading mb-2 text-muted-900 dark:text-muted-100" x-text="title"></h3>
     <!-- Body level: modal message -->
     <p class="text-sm leading-relaxed text-muted-600 dark:text-muted-300 mb-4" x-text="message"></p>

     <!-- Entity counts — vertical rhythm -->
     <div x-show="counts || busy" x-cloak class="mb-4 space-y-1">
       <template x-if="busy">
         <!-- Body level -->
         <p class="text-sm leading-relaxed text-muted-500 dark:text-muted-400">Loading counts...</p>
       </template>
       <template x-for="line in countLines" :key="line.label">
         <!-- Body level -->
         <div class="flex justify-between text-sm leading-relaxed">
           <span class="text-muted-600 dark:text-muted-300" x-text="line.label"></span>
           <span class="font-medium text-muted-800 dark:text-muted-200" x-text="line.value"></span>
         </div>
       </template>
     </div>

     <!-- Error — Body level -->
     <div x-show="error" x-cloak class="mb-4 p-2 bg-danger-50 dark:bg-danger-900 border border-danger-200 dark:border-danger-800 rounded-card text-sm leading-relaxed text-danger-700 dark:text-danger-300">
       <span x-text="error"></span>
     </div>

     <!-- Actions -->
     <template x-if="!error">
       <div class="flex justify-end gap-2">
         <button @click="cancel()" type="button"
           class="px-4 py-2 bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200 rounded-card hover:bg-surface-300 dark:hover:bg-muted-500 text-sm leading-relaxed transition">Cancel</button>
         <button @click="confirm()" type="button" :disabled="busy"
           class="px-4 py-2 bg-danger-600 text-white rounded-card hover:bg-danger-700 disabled:opacity-50 text-sm leading-relaxed transition">Confirm</button>
       </div>
     </template>

     <template x-if="error">
       <div class="flex justify-end">
         <button @click="close()" type="button"
           class="px-4 py-2 bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200 rounded-card hover:bg-surface-300 dark:hover:bg-muted-500 text-sm leading-relaxed transition">Close</button>
       </div>
     </template>
   </div>
 </div>