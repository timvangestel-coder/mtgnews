<h2 class="text-2xl font-bold mb-4">Admin Panel</h2>

<!-- Tab Navigation — adminTabs() is loaded from /scripts/admin-tabs.js via layout.ejs -->
<div class="mb-6" x-data="adminTabs()" data-admin-default-tab="<%= tab || 'channels' %>">
  <div class="flex gap-2 mb-6">
    <button @click="switchTab('channels')"
      :class="activeTab === 'channels' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Channels
    </button>
    <button @click="switchTab('topics')"
      :class="activeTab === 'topics' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Topics
    </button>
    <button @click="switchTab('polling')"
      :class="activeTab === 'polling' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Polling
    </button>
    <button @click="switchTab('data')"
      :class="activeTab === 'data' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Data
    </button>
  </div>

  <!-- Channels Tab -->
  <template x-if="activeTab === 'channels'">
    <div id="channels-tab-content" x-init="htmx.process($el)">
      <%- include('admin/_channelsTab', { channels, topics }) %>
    </div>
  </template>

  <!-- Topics Tab -->
  <template x-if="activeTab === 'topics'">
    <div id="topics-tab-content" x-init="htmx.process($el)">
      <%- include('admin/_topicsTab', { topics, defaultPrompt }) %>
    </div>
  </template>

  <!-- Polling Tab -->
  <template x-if="activeTab === 'polling'">
    <div id="polling-tab-content" x-init="htmx.process($el)">
      <%- include('admin/_pollingTab', { state: currentRunState }) %>
    </div>
  </template>

  <!-- Data Tab -->
  <template x-if="activeTab === 'data'">
    <div id="data-tab-content">
      <%- include('admin/_dataTab', { softDeleteCounts, softDeleteTotal }) %>
    </div>
  </template>
</div>

<!-- Delete Confirmation Modal — top-level, reusable from any tab -->
<div x-data="deleteModal()"
     x-show="open"
     @keydown.escape.window="cancel()"
     class="fixed inset-0 z-50 flex items-center justify-center"
     style="display: none;">
   <!-- Backdrop -->
   <div class="fixed inset-0 bg-black/50" @click="cancel()"></div>

   <!-- Card -->
   <div class="relative bg-white rounded-lg shadow-xl max-w-md w-full p-6 mx-4">
     <h3 class="text-lg font-semibold mb-2" x-text="title"></h3>
     <p class="text-sm text-gray-600 mb-4" x-text="message"></p>

     <!-- Entity counts -->
     <div x-show="counts || busy" x-cloak class="mb-4 space-y-1">
       <template x-if="busy">
         <p class="text-sm text-gray-500">Loading counts...</p>
       </template>
       <template x-for="line in countLines" :key="line.label">
         <div class="flex justify-between text-sm">
           <span class="text-gray-600" x-text="line.label"></span>
           <span class="font-medium" x-text="line.value"></span>
         </div>
       </template>
     </div>

     <!-- Error -->
     <div x-show="error" x-cloak class="mb-4 p-2 bg-red-50 border border-red-200 rounded text-sm text-red-700">
       <span x-text="error"></span>
     </div>

     <!-- Actions -->
     <template x-if="!error">
       <div class="flex justify-end gap-2">
         <button @click="cancel()" type="button"
           class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">Cancel</button>
         <button @click="confirm()" type="button" :disabled="busy"
           class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 disabled:opacity-50">Confirm</button>
       </div>
     </template>

     <template x-if="error">
       <div class="flex justify-end">
         <button @click="close()" type="button"
           class="px-4 py-2 bg-gray-200 text-gray-700 rounded hover:bg-gray-300">Close</button>
       </div>
     </template>
   </div>
 </div>