<!-- Display level: page title -->
<h2 class="text-2xl font-bold tracking-display text-muted-900 dark:text-muted-100 mb-4">Admin Panel</h2>

<!-- Tab Navigation — adminTabs() is loaded from /scripts/admin-tabs.js via layout.ejs -->
<div class="mb-6" x-data="adminTabs()" data-admin-default-tab="<%= tab || 'channels' %>">
  <div class="flex gap-2 mb-6">
    <button @click="switchTab('channels')"
      :class="activeTab === 'channels' ? 'bg-brand-600 text-white' : 'bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Channels
    </button>
    <button @click="switchTab('topics')"
      :class="activeTab === 'topics' ? 'bg-brand-600 text-white' : 'bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Topics
    </button>
    <button @click="switchTab('polling')"
      :class="activeTab === 'polling' ? 'bg-brand-600 text-white' : 'bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Polling
    </button>
    <button @click="switchTab('data')"
      :class="activeTab === 'data' ? 'bg-brand-600 text-white' : 'bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Data
    </button>
  </div>

  <!-- Channels Tab -->
  <template x-if="activeTab === 'channels'">
    <div id="channels-tab-content" x-init="htmx.process($el)">
      <%- include('admin/_channelsTab', { channels, topics }) %>
    </div>
  </template>

  <!-- Topics Tab -->
  <template x-if="activeTab === 'topics'">
    <div id="topics-tab-content" x-init="htmx.process($el)">
      <%- include('admin/_topicsTab', { topics, defaultPrompt }) %>
    </div>
  </template>

  <!-- Polling Tab -->
  <template x-if="activeTab === 'polling'">
    <div id="polling-tab-content" x-init="htmx.process($el)">
      <%- include('admin/_pollingTab', { state: currentRunState }) %>
    </div>
  </template>

  <!-- Data Tab -->
  <template x-if="activeTab === 'data'">
    <div id="data-tab-content">
      <%- include('admin/_dataTab', { softDeleteCounts, softDeleteTotal }) %>
    </div>
  </template>
</div>

<!-- Delete Confirmation Modal — top-level, reusable from any tab -->
<div x-data="deleteModal()"
     x-show="open"
     @keydown.escape.window="cancel()"
      class="fixed inset-0 z-50 flex items-center justify-center hidden">
   <!-- Backdrop -->
   <div class="fixed inset-0 bg-black/50" @click="cancel()"></div>

   <!-- Card — p-4 detail padding -->
   <div class="relative bg-white dark:bg-slate-800 rounded-card shadow-panel-lg max-w-md w-full p-4 mx-4 border border-surface-200 dark:border-muted-700">
     <!-- Heading level: modal title -->
     <h3 class="text-lg font-semibold tracking-heading mb-2 text-muted-900 dark:text-muted-100" x-text="title"></h3>
     <!-- Body level: modal message -->
     <p class="text-sm leading-relaxed text-muted-600 dark:text-muted-300 mb-4" x-text="message"></p>

     <!-- Entity counts — vertical rhythm -->
     <div x-show="counts || busy" x-cloak class="mb-4 space-y-1">
       <template x-if="busy">
         <!-- Body level -->
         <p class="text-sm leading-relaxed text-muted-500 dark:text-muted-400">Loading counts...</p>
       </template>
       <template x-for="line in countLines" :key="line.label">
         <!-- Body level -->
         <div class="flex justify-between text-sm leading-relaxed">
           <span class="text-muted-600 dark:text-muted-300" x-text="line.label"></span>
           <span class="font-medium text-muted-800 dark:text-muted-200" x-text="line.value"></span>
         </div>
       </template>
     </div>

     <!-- Error — Body level -->
     <div x-show="error" x-cloak class="mb-4 p-2 bg-danger-50 dark:bg-danger-900 border border-danger-200 dark:border-danger-800 rounded-card text-sm leading-relaxed text-danger-700 dark:text-danger-300">
       <span x-text="error"></span>
     </div>

     <!-- Actions -->
     <template x-if="!error">
       <div class="flex justify-end gap-2">
         <button @click="cancel()" type="button"
           class="px-4 py-2 bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200 rounded-card hover:bg-surface-300 dark:hover:bg-muted-500 text-sm leading-relaxed transition">Cancel</button>
         <button @click="confirm()" type="button" :disabled="busy"
           class="px-4 py-2 bg-danger-600 text-white rounded-card hover:bg-danger-700 disabled:opacity-50 text-sm leading-relaxed transition">Confirm</button>
       </div>
     </template>

     <template x-if="error">
       <div class="flex justify-end">
         <button @click="close()" type="button"
           class="px-4 py-2 bg-surface-200 dark:bg-muted-600 text-muted-700 dark:text-muted-200 rounded-card hover:bg-surface-300 dark:hover:bg-muted-500 text-sm leading-relaxed transition">Close</button>
       </div>
     </template>
   </div>
 </div>