<h2 class="text-2xl font-bold mb-4">Admin Panel</h2>

<!-- Tab Navigation -->
<div class="mb-6" x-data="{ activeTab: 'channels' }">
  <div class="flex gap-2 mb-6">
    <button @click="activeTab = 'channels'"
      :class="activeTab === 'channels' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Channels
    </button>
    <button @click="activeTab = 'topics'"
      :class="activeTab === 'topics' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Topics
    </button>
    <button @click="activeTab = 'polling'"
      :class="activeTab === 'polling' ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700'"
      class="px-4 py-2 rounded-full font-medium text-sm hover:opacity-90 transition">
      Polling
    </button>
  </div>

  <!-- Channels Tab -->
  <template x-if="activeTab === 'channels'">
    <div>
       <!-- Add Channel -->
       <div class="mb-6">
         <h3 class="text-xl font-semibold mb-2">Add Channel</h3>
         <form action="/admin/channels/add" method="post" class="flex flex-col gap-2">
           <div class="flex gap-2">
             <input type="text" name="channel_id" placeholder="YouTube Channel ID (e.g. UCxxxx)"
                class="flex-1 px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500" required />
             <select name="topic_id" class="px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500">
               <option value="">Select Topic</option>
               <% topics.forEach(function(topic) { %>
                 <option value="<%= topic.id %>"><%= topic.short_name %></option>
               <% }); %>
             </select>
             <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700">Add</button>
           </div>
         </form>
       </div>

      <!-- WatchList -->
      <div>
        <h3 class="text-xl font-semibold mb-2">WatchList</h3>

        <% if (channels && channels.length > 0) { %>
          <div class="space-y-3">
            <% channels.forEach(function(ch) { %>
              <div class="flex items-center gap-4 p-3 bg-gray-50 rounded">
                <!-- Avatar -->
                <% if (ch.avatar_url) { %>
                  <img src="<%= ch.avatar_url %>" alt="" class="w-10 h-10 rounded-full" />
                <% } else { %>
                  <div class="w-10 h-10 rounded-full bg-gray-300 flex items-center justify-center text-xs text-gray-600">
                    <%= (ch.display_name || ch.channel_id).charAt(0) %>
                  </div>
                <% } %>

                <!-- Info -->
                <div class="flex-1">
                  <p class="font-medium"><%= ch.display_name || ch.channel_id %></p>
                  <p class="text-xs text-gray-500">
                    ID: <%= ch.channel_id %>
                    <% if (ch.last_poll_date) { %>
                      &middot; Last poll: <%= new Date(ch.last_poll_date).toLocaleString() %>
                    <% } else { %>
                      &middot; Never polled
                    <% } %>
                  </p>
                </div>

                <!-- Active Toggle -->
                <form action="/admin/channels/toggle" method="post" class="flex items-center gap-2">
                  <input type="hidden" name="channel_id" value="<%= ch.channel_id %>" />
                  <input type="hidden" name="active" value="<%= !ch.active %>" />
                  <label class="inline-flex items-center cursor-pointer">
                    <input type="checkbox" <%= ch.active ? 'checked' : '' %> class="sr-only peer" onchange="this.form.submit()" />
                    <div class="w-9 h-5 bg-gray-300 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-blue-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-blue-600"></div>
                  </label>
                  <span class="text-xs text-gray-500"><%= ch.active ? 'Active' : 'Inactive' %></span>
                </form>

                 <!-- Topic Badge -->
                 <% var chTopic = topics.find(function(t) { return t.id === ch.topic_id; }); %>
                 <% if (chTopic) { %>
                   <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium" title="Topic: <%= chTopic.short_name %>"><%= chTopic.short_name %></span>
                 <% } else { %>
                   <span class="px-2 py-1 bg-amber-100 text-amber-700 rounded-full text-xs font-medium" title="No topic assigned">No topic</span>
                 <% } %>

                 <!-- Change Topic -->
                 <form action="/admin/channels/update-topic" method="post" class="flex items-center gap-1">
                   <input type="hidden" name="channel_id" value="<%= ch.channel_id %>" />
                   <select name="topic_id" onchange="this.form.submit()" class="text-xs px-1 py-1 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500">
                     <% var noTopic = !ch.topic_id; %>
                     <option value="<%= noTopic ? '' : 'x' %>"<%= noTopic ? ' selected' : '' %>></option>
                     <% topics.forEach(function(topic) { %>
                       <% var sel = ch.topic_id === topic.id; %>
                       <option value="<%= topic.id %>"<%= sel ? ' selected' : '' %>><%= topic.short_name %></option>
                     <% }); %>
                   </select>
                 </form>

                <!-- Remove -->
                <form action="/admin/channels/remove" method="post">
                  <input type="hidden" name="channel_id" value="<%= ch.channel_id %>" />
                  <button type="submit" class="text-sm text-red-600 hover:text-red-800"
                    onclick="return confirm('Remove <%= ch.display_name || ch.channel_id %>?')">Remove</button>
                </form>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-gray-500">No channels in WatchList. Add one above.</p>
        <% } %>
      </div>
    </div>
  </template>

  <!-- Topics Tab -->
  <template x-if="activeTab === 'topics'">
    <div>
      <h3 class="text-xl font-semibold mb-2">Topics</h3>

      <!-- Add Topic Form -->
      <div class="mb-6" x-data="">
        <h4 class="text-lg font-medium mb-2">Add Topic</h4>
        <form action="/admin/topics" method="post" class="flex flex-col gap-2 max-w-xl">
          <input type="text" name="key" placeholder="Key (slug, unique)"
             class="px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500" required />
          <input type="text" name="short_name" placeholder="Short Name"
             class="px-3 py-2 border rounded focus:outline-none focus:ring-2 focus:ring-blue-500" required />
          <textarea name="filter_text" placeholder="Filter Text" rows="2"
            class="px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"></textarea>
          <button type="submit" class="px-4 py-2 bg-green-600 text-white rounded hover:bg-green-700 self-start">Add Topic</button>
        </form>
      </div>

      <!-- Topics Table -->
      <div>
        <% if (topics && topics.length > 0) { %>
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b">
                <th class="py-2 px-3 font-medium">Key</th>
                <th class="py-2 px-3 font-medium">Short Name</th>
                <th class="py-2 px-3 font-medium">Filter Text</th>
                <th class="py-2 px-3 font-medium">Channels</th>
                <th class="py-2 px-3 font-medium">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% topics.forEach(function(topic) { %>
                <tr class="border-b" x-data="{ editing: false }">
                  <template x-if="editing">
                    <!-- Edit Mode -->
                    <tr class="border-b bg-gray-50">
                      <td colspan="5" class="p-3">
                        <form action="/admin/topics/update" method="post" class="flex flex-col gap-2 max-w-xl">
                          <input type="hidden" name="id" value="<%= topic.id %>" />
                          <input type="text" name="key" value="<%= topic.key %>"
                             class="px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" required />
                          <input type="text" name="short_name" value="<%= topic.short_name %>"
                             class="px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" required />
                          <textarea name="filter_text" rows="2"
                            class="px-3 py-2 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"><%= topic.filter_text %></textarea>
                          <div class="flex gap-2">
                            <button type="submit" class="px-3 py-1 bg-green-600 text-white rounded text-sm hover:bg-green-700">Save</button>
                            <button @click.prevent="editing = false" type="button" class="px-3 py-1 bg-gray-300 rounded text-sm hover:bg-gray-400">Cancel</button>
                          </div>
                        </form>
                      </td>
                    </tr>
                  </template>
                  <template x-if="!editing">
                    <tr class="border-b">
                      <td class="py-2 px-3 font-mono text-xs"><%= topic.key %></td>
                      <td class="py-2 px-3"><%= topic.short_name %></td>
                       <% var ft = topic.filter_text || ''; %>
                       <td class="py-2 px-3 max-w-[200px] truncate" title="<%= ft %>"><%= ft.substring(0, 80) %><% if (ft.length > 80) { %>&hellip;<% } %></td>
                      <td class="py-2 px-3"><%= topic.channel_count || 0 %></td>
                      <td class="py-2 px-3 flex gap-3">
                        <button @click="editing = true" class="text-blue-600 hover:text-blue-800 text-xs">Edit</button>
                        <form action="/admin/topics/delete" method="post" class="inline">
                          <input type="hidden" name="id" value="<%= topic.id %>" />
                          <% if ((topic.channel_count || 0) > 0) { %>
                            <button type="submit" class="text-red-600 hover:text-red-800 text-xs"
                              onclick="return confirm('Delete this topic? <%= topic.channel_count %> channel(s) will be unassigned.')')">Delete</button>
                          <% } else { %>
                            <button type="submit" class="text-red-600 hover:text-red-800 text-xs"
                              onclick="return confirm('Delete this topic?')">Delete</button>
                          <% } %>
                        </form>
                      </td>
                    </tr>
                  </template>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p class="text-gray-500">No topics yet. Add one above.</p>
        <% } %>
      </div>
    </div>
  </template>

  <!-- Polling Tab -->
  <template x-if="activeTab === 'polling'">
    <div>
      <!-- Run Poll Now -->
      <div class="mb-6">
        <h3 class="text-xl font-semibold mb-2">Run Poll</h3>
        <form action="/admin/poll/trigger" method="post" class="flex gap-2 items-center">
          <label for="lookback_days" class="text-sm text-gray-600">Lookback (days):</label>
          <input id="lookback_days" name="lookback_days" type="number" min="0" max="365" value="2"
            class="w-20 px-2 py-1 border rounded text-sm focus:outline-none focus:ring-2 focus:ring-blue-500" />
          <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 font-medium">
            Run Poll Now
          </button>
        </form>
      </div>

      <!-- Live Progress Widget -->
      <div id="progress-widget" class="mb-6 p-4 bg-gray-50 rounded"
        hx-get="/admin/poll/progress"
        hx-trigger="every 3s"
        hx-swap="outerHTML">
        <% if (currentRun) { %>
          <h3 class="font-semibold mb-2">
            Run #<%= currentRun.id %> —
            <% if (currentRun.status === 'running') { %>
              <span class="text-amber-600">running...</span>
            <% } else { %>
              <span class="<%= currentRun.status === 'done' ? 'text-green-600' : 'text-red-600' %>"><%= currentRun.status %></span>
            <% } %>
          </h3>
          <div class="space-y-1">
            <% currentProgress.forEach(function(p) { %>
              <div class="text-sm flex justify-between">
                <span><%= p.display_name || p.channel_id %></span>
                <span class="<%= p.status === 'done' ? 'text-green-600' : p.status === 'failed' ? 'text-red-600' : 'text-amber-600' %>">
                  <%= p.status %><%= p.signals_found > 0 ? ' (' + p.signals_found + ')' : '' %>
                </span>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-gray-500">No active poll run.</p>
        <% } %>
      </div>
    </div>
  </template>
</div>