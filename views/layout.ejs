<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'MTG News' %></title>
  <style>
    /* Hide table headers in chat answer tables — keeps two-column tbody layout */
    .chat-answer table thead { display: none; }
    /* Phase transition animation — smooth fade between phase label changes */
    .chat-phase-text,
    .phase-micro-label {
      transition: opacity 0.15s ease;
    }
    .chat-phase-text.phase-fading,
    .phase-micro-label.phase-fading {
      opacity: 0;
    }
    /* Typing dots stagger animation */
    .typing-dot-1 { animation-delay: 0ms; }
    .typing-dot-2 { animation-delay: 150ms; }
    .typing-dot-3 { animation-delay: 300ms; }
    /* field-sizing: content polyfill for textarea auto-grow */
    .field-sizing-content { field-sizing: content; }
     /* Signal detail container height via CSS custom property */
     :root {
       --main-content-height: calc(100vh - 160px);
       /* Brand token colors for use in inline CSS (e.g. bullet markers) */
       --color-brand-600: #4f46e5;
       --color-brand-400: #818cf8;
     }
     .signal-detail-main { height: var(--main-content-height); min-height: 400px; }
     /* Timestamp navigation pills — used in summary, transcript, and chat answers.
        Defined here (not via Tailwind dark: variants) because the class strings are
        built in TypeScript and are not visible to the Tailwind CDN JIT scanner. */
     .ts-pill {
       display: inline-flex;
       align-items: center;
       background-color: #e0e7ff; /* indigo-100 */
       color: #4338ca;            /* indigo-700 */
       padding: 2px 8px;
       border-radius: 4px;
       font-size: 0.875rem;
       font-weight: 500;
       transition: background-color 0.15s;
       text-decoration: none;
     }
     .ts-pill:hover { background-color: #c7d2fe; /* indigo-200 */ }
     html.dark .ts-pill {
       background-color: rgb(51 65 85);  /* slate-700 */
       color: rgb(165 180 252);          /* indigo-300 */
     }
     html.dark .ts-pill:hover { background-color: rgb(71 85 105); /* slate-600 */ }
  </style>
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Design token config — must load AFTER Tailwind CDN -->
  <script src="/scripts/tailwind-config.js"></script>
  <script src="https://unpkg.com/htmx.org@2.0.0"></script>
</head>
<body class="bg-surface-50 dark:bg-muted-900 min-h-screen">
  <div x-data="{ sidebarOpen: false }" @keydown.escape.window="sidebarOpen = false" class="flex min-h-screen">

    <!-- Mobile overlay backdrop -->
    <div x-show="sidebarOpen"
         x-transition:enter="transition-opacity ease-linear duration-200"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         x-transition:leave="transition-opacity ease-linear duration-200"
         x-transition:leave-start="opacity-100"
         x-transition:leave-end="opacity-0"
         @click="sidebarOpen = false"
         class="fixed inset-0 bg-muted-900 opacity-75 z-40 md:hidden"></div>

    <!-- Sidebar -->
    <aside id="sidebar-drawer"
            role="dialog"
            aria-modal="true"
            aria-label="Navigation menu"
            :aria-hidden="!sidebarOpen"
            class="fixed top-0 left-0 z-50 h-full w-64 bg-white dark:bg-slate-800 border-r border-surface-200 dark:border-muted-700 transform -translate-x-full transition-transform md:translate-x-0 md:static md:z-auto flex flex-col">

      <!-- Close button (mobile only) -->
      <button @click="sidebarOpen = false"
              aria-label="Close navigation menu"
              class="absolute top-3 right-3 text-muted-400 hover:text-muted-600 dark:text-muted-500 dark:hover:text-muted-300 md:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 rounded">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Brand / Logo -->
      <div class="flex items-center gap-3 px-4 pt-5 pb-6">
        <div class="w-9 h-9 flex items-center justify-center rounded-lg bg-brand-500 text-white font-bold text-lg">M</div>
        <span class="text-lg font-semibold text-muted-800 dark:text-muted-200">MTG News</span>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 px-3 space-y-1" aria-label="Main navigation">
        <!-- Signals — chart-bar icon -->
        <a href="/signals?topicKey=&channelId=&dateFilter=week"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition
                  border-l-4 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500
                  <%= activePage === 'signals'
                        ? 'bg-brand-50 dark:bg-slate-700 text-brand-700 dark:text-brand-400 border-brand-500'
                        : 'text-muted-600 dark:text-muted-400 hover:bg-surface-100 dark:hover:bg-slate-700 border-transparent' %>">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.5604 3.44975 12.0938 4.01562 12.0938H6.89062C7.45547 12.0938 7.90625 12.5604 7.90625 13.125V20.0625C7.90625 20.6274 7.45547 21.0938 6.89062 21.0938H4.01562C3.45078 21.0938 3 20.6274 3 20.0625V13.125ZM8.67188 7.875C8.67188 7.31016 9.12266 6.84375 9.6875 6.84375H12.5625C13.1273 6.84375 13.5781 7.31016 13.5781 7.875V20.0625C13.5781 20.6274 13.1273 21.0938 12.5625 21.0938H9.6875C9.12266 21.0938 8.67188 20.6274 8.67188 20.0625V7.875ZM14.4375 3.75C14.4375 3.18516 14.8883 2.71875 15.4531 2.71875H18.3281C18.893 2.71875 19.3438 3.18516 19.3438 3.75V20.0625C19.3438 20.6274 18.893 21.0938 18.3281 21.0938H15.4531C14.8883 21.0938 14.4375 20.6274 14.4375 20.0625V3.75Z" />
          </svg>
          Signals
        </a>

        <!-- Run History — clock icon -->
        <a href="/polls"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition
                  border-l-4 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500
                  <%= activePage === 'polls'
                        ? 'bg-brand-50 dark:bg-slate-700 text-brand-700 dark:text-brand-400 border-brand-500'
                        : 'text-muted-600 dark:text-muted-400 hover:bg-surface-100 dark:hover:bg-slate-700 border-transparent' %>">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4.5 2.25M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Run History
        </a>

        <!-- Admin — gear icon -->
        <a href="/admin"
           class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition
                  border-l-4 focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500
                  <%= activePage === 'admin'
                        ? 'bg-brand-50 dark:bg-slate-700 text-brand-700 dark:text-brand-400 border-brand-500'
                        : 'text-muted-600 dark:text-muted-400 hover:bg-surface-100 dark:hover:bg-slate-700 border-transparent' %>">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94A8.97 8.97 0 0112 3c.462 0 .924.043 1.376.126m-3.276 1.376A8.96 8.96 0 009 6c0 .462.043.924.126 1.376m-.126 3.544A8.96 8.96 0 009 12c0 .462.043.924.126 1.376m-3.276 1.376A8.97 8.97 0 019 18c.462 0 .924-.043 1.376-.126m-3.276-1.376A8.96 8.96 0 009 15c0-.462-.043-.924-.126-1.376m3.276-1.376A8.96 8.96 0 0012 12c-.462 0-.924-.043-1.376-.126m3.276 1.376A8.97 8.97 0 0115 18c-.462 0-.924-.043-1.376-.126M12 9.75V12m0 0v2.25m0-2.25H9.75M12 12h2.25" />
          </svg>
          Admin Panel
        </a>
      </nav>

      <!-- Sidebar footer — Dark mode toggle -->
      <div class="px-3 py-4 border-t border-surface-200 dark:border-muted-700">
        <button onclick="DarkMode.toggle()"
                aria-label="Toggle dark mode"
                class="flex items-center gap-3 w-full px-3 py-2.5 rounded-lg text-sm font-medium text-muted-600 dark:text-muted-400 hover:bg-surface-100 dark:hover:bg-slate-700 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
          <!-- Sun icon (shown in light mode) -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 block dark:hidden">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon (shown in dark mode) -->
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 hidden dark:block">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 p-6">
      <!-- Hamburger menu button (mobile only) -->
      <button @click="sidebarOpen = true"
              :aria-expanded="sidebarOpen.toString()"
              aria-controls="sidebar-drawer"
              aria-label="Open navigation menu"
              class="mb-4 px-3 py-2 rounded-lg bg-white dark:bg-slate-800 border border-surface-200 dark:border-muted-700 text-muted-600 dark:text-muted-400 hover:bg-surface-100 dark:hover:bg-slate-700 transition md:hidden focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
      <%- body %>
    </main>
  </div>
  <!-- Extracted page scripts — must load before Alpine so global functions are available -->
  <% if (typeof scripts !== 'undefined') { %><%- scripts %><% } %>

  <!-- UI State module — must load before Alpine so window.UiState is defined -->
  <% if (activePage === 'signals' || activePage === 'signal-detail' || activePage === 'admin') { %>
  <script src="/scripts/ui-state.js"></script>
  <% } %>

  <!-- ScopeSource — pure scope utility, loaded before chat-panel.js -->
  <script defer src="/scripts/scope-source.js"></script>
  <!-- TimestampNav — timestamp click delegation, loaded before Alpine -->
  <script defer src="/scripts/timestamp-nav.js"></script>
  <!-- Chat Panel component — must load before Alpine so window.chatPanel is defined -->
  <script defer src="/scripts/chat-panel.js"></script>
  <!-- Dark Mode module — must load before Alpine so window.DarkMode is defined -->
  <script src="/scripts/dark-mode.js"></script>

  <!-- Alpine.js — pinned version for consistent behavior across environments -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
</body>
</html>