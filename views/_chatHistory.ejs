<div class="chat-history space-y-3">
  <% if (messages && messages.length > 0) { %>
    <% messages.forEach(function(msg) { %>
      <% var status = statusMap && statusMap[msg.id] ? statusMap[msg.id] : (msg.answer ? 'done' : 'pending'); %>
      <div class="chat-entry border-t border-gray-200 pt-3 pb-2 relative" data-chat-id="<%= msg.id %>" id="entry-<%= msg.id %>">
        <div class="chat-question text-sm">
          <strong>Q:</strong> <%= msg.question %>
        </div>
        <% if (status === 'failed') { %>
          <div class="chat-answer text-sm text-red-600 mt-1">
            <strong>A:</strong> <span class="font-medium">failed</span>
          </div>
        <% } else if (status === 'pending') { %>
          <div
            class="chat-answer text-sm text-gray-500 mt-1"
            hx-get="/chat/<%= msg.id %>/status"
            hx-trigger="every 2s"
            hx-swap="outerHTML"
            hx-select=".chat-answer"
          >
            <strong>A:</strong> <span class="animate-pulse">processing...</span>
          </div>
        <% } else { %>
          <div class="chat-answer text-sm text-gray-700 mt-1 whitespace-pre-wrap">
            <strong>A:</strong> <%- msg.answer %>
          </div>
        <% } %>
        <button
          data-chat-delete
          hx-delete="/chat/<%= msg.id %>"
          hx-on::after-request="if(event.detail.xhr.status === 204) this.closest('.chat-entry').remove()"
          type="button"
          class="absolute top-2 right-2 text-gray-400 hover:text-red-500 transition-colors p-1"
          title="Delete"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
          </svg>
        </button>
      </div>
    <% }); %>
  <% } else { %>
    <div class="chat-empty text-sm text-gray-500 italic">No chat history yet. Ask a question!</div>
  <% } %>
</div>