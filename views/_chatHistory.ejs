<div class="chat-history space-y-3">
  <% if (messages && messages.length > 0) { %>
    <% messages.forEach(function(msg) { %>
      <% var status = statusMap && statusMap[msg.id] ? statusMap[msg.id] : (msg.answer ? 'done' : 'pending'); %>
      <div id="entry-<%= msg.id %>" class="chat-entry" data-chat-id="<%= msg.id %>" data-chat-status="<%= status %>">

        <!-- User question bubble -->
        <div class="flex items-start gap-2 chat-question-bubble">
          <div class="w-7 h-7 rounded-full bg-muted-300 dark:bg-muted-600 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">U</div>
          <div class="bg-white dark:bg-slate-700 rounded-xl rounded-tl-sm px-3 py-2 shadow-sm max-w-[85%]">
            <p class="text-sm text-muted-900 dark:text-muted-100"><%= msg.question %></p>
          </div>
        </div>

        <!-- AI answer / status bubble -->
        <% if (status === 'failed') { %>
          <div class="flex items-start gap-2 justify-end chat-answer-bubble mt-1">
            <div class="bg-brand-50 dark:bg-slate-600 rounded-xl rounded-tr-sm px-3 py-2 shadow-sm max-w-[85%]">
              <p class="text-sm text-danger-600 dark:text-danger-400 font-medium">Response failed</p>
            </div>
            <div class="w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">AI</div>
          </div>

        <% } else if (status === 'pending') { %>
          <div class="flex items-start gap-2 justify-end chat-answer-bubble mt-1">
            <div class="bg-brand-50 dark:bg-slate-600 rounded-xl rounded-tr-sm px-3 py-2 shadow-sm max-w-[85%]">
              <div data-chat-id="<%= msg.id %>" data-chat-phase="" data-chat-token-count="0" data-chat-round="1" class="chat-phase-container">
                <!-- Bouncing dots typing indicator -->
                <div class="flex items-center gap-1 typing-dots-indicator">
                  <span class="w-2 h-2 bg-brand-400 dark:bg-brand-300 rounded-full animate-bounce typing-dot-1"></span>
                  <span class="w-2 h-2 bg-brand-400 dark:bg-brand-300 rounded-full animate-bounce typing-dot-2"></span>
                  <span class="w-2 h-2 bg-brand-400 dark:bg-brand-300 rounded-full animate-bounce typing-dot-3"></span>
                </div>
                <span class="chat-phase-text text-xs text-muted-400 dark:text-muted-500 mt-1 block phase-micro-label">processing...</span>
              </div>
            </div>
            <div class="w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">AI</div>
          </div>

        <% } else { %>
          <div class="flex items-start gap-2 justify-end chat-answer-bubble mt-1">
            <div class="bg-brand-50 dark:bg-slate-600 rounded-xl rounded-tr-sm px-3 py-2 shadow-sm max-w-[85%]">
              <div class="chat-answer text-sm text-muted-900 dark:text-muted-100">
                <%- msg.answerHtml %>
              </div>
            </div>
            <div class="w-7 h-7 rounded-full bg-brand-500 flex items-center justify-center flex-shrink-0 text-white text-xs font-medium">AI</div>
          </div>
        <% } %>

        <!-- Delete button (aligned with bottom of answer box, right side) -->
        <div class="flex justify-end -mt-6">
          <button
            data-chat-delete
            hx-delete="/chat/<%= msg.id %>"
            hx-on::after-request="if(event.detail.xhr.status === 204) this.closest('.chat-entry').remove()"
            type="button"
            style="padding:4px;border-radius:9999px;border:none;background:#f1f5f9;color:#64748b;cursor:pointer;display:flex;align-items:center;justify-content:center;"
            onmouseover="this.style.color='#dc2626';this.style.background='#fef2f2'"
            onmouseout="this.style.color='#64748b';this.style.background='#f1f5f9'"
            title="Delete"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
          </button>
        </div>

      </div>
    <% }); %>
  <% } else { %>
    <div class="chat-empty text-sm text-muted-400 dark:text-muted-500 italic text-center py-8">No chat history yet. Ask a question!</div>
  <% } %>
</div>